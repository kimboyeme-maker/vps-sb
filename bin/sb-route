#!/usr/bin/env bash
set -euo pipefail

export SB_ROOT="${SB_ROOT:-$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)}"
F="$SB_ROOT/env/routes.json"

log() { printf '[%s] %s\n' "$(date +%H:%M:%S)" "$*" >&2; }
die() { log "FAIL: $*"; exit 1; }

VALID_TYPES="domain domain-suffix domain-keyword domain-regex ip-cidr"

summary() {
  cat <<'S'
summary:
  sb-route 管理自定义分流规则（写 env/routes.json，编译由 sb-apply 完成）。

  语义（sb-apply 编译后的 route.rules 顺序）：
    sniff -> ip_is_private reject -> sb-route 规则 -> auth_user upstream -> final direct

  即 sb-route 是"硬覆盖层"：默认插在用户级 upstream 分流之前（position=before-upstream），
  可覆盖用户默认出口。position=after-upstream 则相反（高级）。

  规则可 global（影响所有用户）或 scoped（--user / --inbound，仅影响指定用户/入站）。
  global 规则创建时会 WARN，因为它在用户级 upstream 前生效、影响所有用户。

  v1 仅支持直接可映射字段：domain / domain-suffix / domain-keyword / domain-regex / ip-cidr。
  geosite / geoip 需要 rule_set（未启用），直接报错，不静默接受。
S
}

usage() {
  cat <<'U'
usage:
  sb-route enable | disable
  sb-route position before-upstream | after-upstream
  sb-route add <match_type> <value> <outbound> [--user U]... [--inbound I]...
  sb-route list
  sb-route rm <index>
  sb-route reset
  sb-route show
  sb-route help | -h | --help

match_type:
  domain | domain-suffix | domain-keyword | domain-regex | ip-cidr
  （geosite / geoip 需 rule_set，v1 未启用，会报错）

scope（可重复、可混用两种写法）：
  --user <name|alias>     或  auth_user=<name>
  --inbound <tag>         或  inbound=<tag>
  不带任何 scope = global 规则（影响所有用户，创建时 WARN）

examples:
  sb-route enable
  sb-route add domain-suffix openai.com  upstream --user default
  sb-route add domain-suffix netflix.com direct   --user chatgpt
  sb-route add domain-suffix github.com  direct   --user chatgpt --inbound vless-in
  sb-route add ip-cidr      1.1.1.0/24   direct
  sb-route position after-upstream
  sb-route list
  sb-route rm 2

notes:
  - 改完跑 sb-apply 生效
  - outbound 必须是已存在的 outbound tag（direct / upstream / sb-outbound 加的），拼错 sing-box check 会拦
U
}

command -v jq >/dev/null || die "缺依赖 jq"
mkdir -p "$SB_ROOT/env"

ensure_file() {
  [[ -f "$F" ]] || printf '{\n  "enabled": false,\n  "position": "before-upstream",\n  "rules": []\n}\n' > "$F"
  # 补缺字段（幂等）
  local tmp; tmp="$(mktemp)"
  jq '
    (.enabled //= false)
    | (.position //= "before-upstream")
    | (.rules //= [])
  ' "$F" > "$tmp" && install -m 600 "$tmp" "$F"; rm -f "$tmp"
}

write_json() {
  local tmp; tmp="$(mktemp)"
  cat > "$tmp"
  jq -e . "$tmp" >/dev/null || { rm -f "$tmp"; die "内部错误：生成了非法 JSON"; }
  install -m 600 "$tmp" "$F"; rm -f "$tmp"
}

cmd="${1:-}"; [[ $# -gt 0 ]] && shift || true

case "$cmd" in
  -h|--help|help) summary; echo; usage; exit 0 ;;
  summary) summary; exit 0 ;;
esac

ensure_file

case "$cmd" in
  enable)  jq '.enabled=true'  "$F" | write_json; log "OK: routes enabled。跑 sb-apply 生效。" ;;
  disable) jq '.enabled=false' "$F" | write_json; log "OK: routes disabled。跑 sb-apply 生效。" ;;

  position)
    p="${1:-}"
    [[ "$p" == "before-upstream" || "$p" == "after-upstream" ]] || die "position 只能 before-upstream | after-upstream"
    jq --arg p "$p" '.position=$p' "$F" | write_json
    log "OK: position=$p。跑 sb-apply 生效。"
    ;;

  add)
    mt="${1:-}"; val="${2:-}"; ob="${3:-}"
    [[ -n "$mt" && -n "$val" && -n "$ob" ]] || { usage >&2; die "add 需要 <match_type> <value> <outbound>"; }
    shift 3 || true

    case "$mt" in
      geosite|geoip) die "geosite/geoip 需要 rule_set 支持，当前 sb-route v1 未启用。请先用 domain/domain-suffix/domain-keyword/domain-regex/ip-cidr。" ;;
    esac
    grep -qw -- "$mt" <<<"$VALID_TYPES" || die "不支持的 match_type '$mt'。可选：$VALID_TYPES"

    users=(); inbounds=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --user)    shift; [[ $# -gt 0 ]] || die "--user 缺参数"; users+=("$1") ;;
        --inbound) shift; [[ $# -gt 0 ]] || die "--inbound 缺参数"; inbounds+=("$1") ;;
        auth_user=*) users+=("${1#auth_user=}") ;;
        inbound=*)   inbounds+=("${1#inbound=}") ;;
        *) die "未知参数 '$1'（scope 用 --user/--inbound 或 auth_user=/inbound=）" ;;
      esac
      shift
    done

    au_json="[]"; [[ ${#users[@]}    -gt 0 ]] && au_json="$(printf '%s\n' "${users[@]}"    | jq -R . | jq -sc .)"
    in_json="[]"; [[ ${#inbounds[@]} -gt 0 ]] && in_json="$(printf '%s\n' "${inbounds[@]}" | jq -R . | jq -sc .)"

    if [[ ${#users[@]} -eq 0 && ${#inbounds[@]} -eq 0 ]]; then
      log "WARN: 这是 global sb-route 规则，会在用户级 upstream 分流前生效，影响所有用户。"
    fi

    jq --arg mt "$mt" --arg val "$val" --arg ob "$ob" \
       --argjson au "$au_json" --argjson in "$in_json" '
      .rules += [
        { match_type:$mt, match_value:$val, outbound:$ob }
        + (if ($au|length)>0 then {auth_user:$au} else {} end)
        + (if ($in|length)>0 then {inbound:$in} else {} end)
      ]
    ' "$F" | write_json
    log "OK: 已加规则 [$mt $val -> $ob]$([[ ${#users[@]} -gt 0 ]] && echo " user=${users[*]}")$([[ ${#inbounds[@]} -gt 0 ]] && echo " inbound=${inbounds[*]}")。跑 sb-apply 生效。"
    ;;

  list|show)
    en="$(jq -r '.enabled' "$F")"; pos="$(jq -r '.position' "$F")"
    printf 'routes: enabled=%s position=%s\n' "$en" "$pos"
    jq -r '.rules | to_entries[] |
      "  [\(.key)] \(.value.match_type) \(.value.match_value) -> \(.value.outbound)" +
      (if (.value.auth_user // [])|length>0 then "  user=\(.value.auth_user|join(","))" else "" end) +
      (if (.value.inbound   // [])|length>0 then "  inbound=\(.value.inbound|join(","))" else "" end) +
      (if ((.value.auth_user // [])|length==0) and ((.value.inbound // [])|length==0) then "  [GLOBAL]" else "" end)
    ' "$F"
    ;;

  rm)
    idx="${1:-}"
    [[ "$idx" =~ ^[0-9]+$ ]] || die "rm 需要数字 index（见 sb-route list）"
    n="$(jq '.rules|length' "$F")"
    (( idx < n )) || die "index $idx 越界（共 $n 条，0..$((n-1))）"
    jq --argjson i "$idx" 'del(.rules[$i])' "$F" | write_json
    log "OK: 已删规则 [$idx]。跑 sb-apply 生效。"
    ;;

  reset)
    jq '.rules=[]' "$F" | write_json
    log "OK: 已清空所有规则（enabled/position 保留）。跑 sb-apply 生效。"
    ;;

  "") usage >&2; die "缺子命令" ;;
  *)  usage >&2; die "未知子命令 '$cmd'" ;;
esac
