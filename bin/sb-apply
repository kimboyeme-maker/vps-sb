#!/usr/bin/env bash
set -euo pipefail

export SB_ROOT="${SB_ROOT:-$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)}"
ENV_FILE="$SB_ROOT/env/node.env"
USERS_FILE="$SB_ROOT/env/users.json"
INBOUNDS_FILE="$SB_ROOT/env/inbounds.json"
OUTBOUND_PATCH_FILE="$SB_ROOT/env/outbound-patch.json"
DNS_FILE="$SB_ROOT/env/dns.json"
CERT_META_FILE="$SB_ROOT/env/cert.json"
TPL="$SB_ROOT/templates/config.json.tpl"
OUT="$SB_ROOT/out/config.json"

log() { printf '[%s] %s\n' "$(date +%H:%M:%S)" "$*" >&2; }
dbg() { [[ "${DEBUG:-0}" == 1 ]] && printf '[debug] %s\n' "$*" >&2 || true; }
die() { log "FAIL: $*"; exit 1; }

usage() {
  cat <<'U'
usage:
  sb-apply
  sb-apply snapshot
  sb-apply help
  sb-apply -h
  sb-apply --help

summary:
  sb-apply 是最终编译器：

    1. 读取 env/node.env
    2. 渲染 templates/config.json.tpl
    3. 自动读取 env/inbounds.json
    4. 自动处理 sb-inbound 记录的 set/rm/clone/delete
    5. 按 inbound type 自动注入 users
    6. 检查所有 inbound listen_port 是否符合端口策略
    7. 自动合并 out/outbounds.json
    8. 自动合并 env/outbound-patch.json（修改 direct 等内置 outbound）
    9. 自动生成 upstream route
   10. 自动校验 UPSTREAM_INBOUNDS
   11. 自动计算 HY2 range
   12. 自动合并 env/dns.json（DNS 策略，默认禁用）
   13. 自动合并 env/routes.json（自定义分流规则，默认禁用）
   14. sing-box check 通过后才落盘
   15. config 变化时重启 sing-box；config 未变则跳过重启，服务未运行时仅 start
   16. UFW 端口对账
   17. HY2 range nftables dnat 对账

  DNS / route overlay（均默认禁用，enabled=false 时对 config 零改动）：
    - env/outbound-patch.json：{patch:{tag→patchObject}}
                       由 sb-outbound direct 编辑；sb-apply 负责 deepmerge 到最终 outbounds，例如 direct.domain_resolver
    - env/dns.json  ：{enabled, servers{tag→{type,server,path,...}}, rules[], final, strategy, route_default}
                       由 sb-dns 编辑；sb-apply 负责拼装成 config.dns + route.default_domain_resolver
    - env/routes.json：{enabled, position, rules[]}
                       每条 rule 是 intent 形式 {match_type, match_value, outbound, auth_user?, inbound?}
                       由 sb-route 编辑；position=before-upstream(默认) 时插在 auth_user upstream 之前（硬覆盖层）
    - 编译一律在 sb-apply 内完成，各编辑器只写 env 文件，不自己 compile

port policy:
  INBOUND_PORT_MIN=20000
    - 所有 inbound listen_port 低于该值直接失败

  INBOUND_PORT_SUGGEST_MIN=40000
    - 低于该值允许，但 WARN
    - 建议所有协议使用 40000+ 高位端口

notes:
  - 改了 node.env / users.json / outbounds.json / inbounds.json 后都跑 sb-apply
  - VLESS_PORT / HY2_PORT / SOCKS5_PORT 是模板 listen_port 必需参数；缺失或为空会直接失败，不自动补默认值
  - sing-box check 不通过时不会覆盖正式 config
  - HY2_RANGE_ENABLED=1 时需要系统有 nft 命令
  - env/cert.json 存在或 env/dns.json.domains 非空时，UFW 会自动保留 80/tcp 供 certbot 续期
  - sb-apply snapshot：apply 全部成功后打一张快照（调 sb-backup），并只保留最近 10 张；平时 sb-apply 不打快照
U
}

DO_SNAPSHOT=0
case "${1:-}" in
  -h|--help|help)
    usage
    exit 0
    ;;
  snapshot|snap)
    DO_SNAPSHOT=1
    ;;
  "")
    ;;
  *)
    usage >&2
    die "未知参数: $1（只支持 snapshot）"
    ;;
esac

[[ -f "$ENV_FILE"   ]] || die "缺 ${ENV_FILE}，先跑 sb-genenv"
[[ -f "$USERS_FILE" ]] || die "缺 ${USERS_FILE}，先跑 sb-genenv"
[[ -f "$TPL"        ]] || die "缺 $TPL"

for dep in envsubst jq sing-box ufw ss awk grep sort head; do
  command -v "$dep" >/dev/null || die "缺依赖 $dep"
done

ensure_env_default() {
  local key="$1"
  local value="$2"

  grep -q "^${key}=" "$ENV_FILE" || {
    echo "${key}=${value}" >> "$ENV_FILE"
    chmod 600 "$ENV_FILE"
  }
}

ensure_env_default "INBOUND_PORT_MIN" "20000"
ensure_env_default "INBOUND_PORT_SUGGEST_MIN" "40000"
ensure_env_default "HY2_RANGE_HOP_INTERVAL" "30"

dbg "载入并导出 node.env"
set -a
source "$ENV_FILE"
set +a

validate_domain_strategy() {
  local ds="${1:-}"

  [[ -z "$ds" ]] && return 0

  case "$ds" in
    prefer_ipv4|prefer_ipv6|ipv4_only|ipv6_only)
      return 0
      ;;
    *)
      die "domain_strategy 仅支持 prefer_ipv4 / prefer_ipv6 / ipv4_only / ipv6_only，收到 '$ds'"
      ;;
  esac
}

validate_port_policy() {
  INBOUND_PORT_MIN="${INBOUND_PORT_MIN:-20000}"
  INBOUND_PORT_SUGGEST_MIN="${INBOUND_PORT_SUGGEST_MIN:-40000}"

  [[ "$INBOUND_PORT_MIN" =~ ^[0-9]+$ ]] || die "INBOUND_PORT_MIN 必须是数字，收到 '$INBOUND_PORT_MIN'"
  [[ "$INBOUND_PORT_SUGGEST_MIN" =~ ^[0-9]+$ ]] || die "INBOUND_PORT_SUGGEST_MIN 必须是数字，收到 '$INBOUND_PORT_SUGGEST_MIN'"

  (( INBOUND_PORT_MIN >= 1 && INBOUND_PORT_MIN <= 65535 )) || die "INBOUND_PORT_MIN 范围必须是 1-65535"
  (( INBOUND_PORT_SUGGEST_MIN >= INBOUND_PORT_MIN && INBOUND_PORT_SUGGEST_MIN <= 65535 )) || die "INBOUND_PORT_SUGGEST_MIN 必须 >= INBOUND_PORT_MIN 且 <= 65535"
}

validate_port() {
  local name="$1"
  local port="$2"

  [[ "$port" =~ ^[0-9]+$ ]] || die "$name 必须是数字，收到 '$port'"
  (( port >= 1 && port <= 65535 )) || die "$name 范围必须是 1-65535，收到 '$port'"
}

validate_offset() {
  local offset="$1"

  [[ "$offset" =~ ^[0-9]+$ ]] || die "HY2_RANGE_OFFSET 必须是数字，收到 '$offset'"
  (( offset >= 2 && offset <= 60000 )) || die "HY2_RANGE_OFFSET 范围建议是 2-60000，收到 '$offset'"
}

env_key_exists() {
  local key="$1"

  grep -q "^${key}=" "$ENV_FILE"
}

env_value() {
  local key="$1"

  printf '%s' "${!key-}"
}

require_env_nonempty() {
  local key="$1"
  local desc="$2"
  local fix="${3:-manual}"
  local value

  if ! env_key_exists "$key"; then
    if [[ "$fix" == "upgrade" ]]; then
      die "node.env 缺必需参数 ${key}（${desc}）。请先跑 sb-genenv upgrade，或手动补齐 ${key}=..."
    fi
    die "node.env 缺必需参数 ${key}（${desc}）。请在 $ENV_FILE 中手动补齐 ${key}=...；如果密钥/端口已丢失，也可以先备份 env/users.json 后删除 $ENV_FILE 并重新跑 sb-genenv。"
  fi

  value="$(env_value "$key")"
  if [[ -z "$value" ]]; then
    die "node.env 必需参数 ${key} 为空（${desc}）。请在 $ENV_FILE 中补齐有效值。"
  fi
}

require_env_port() {
  local key="$1"
  local fix="${2:-manual}"
  local value

  require_env_nonempty "$key" "模板 listen_port 必需参数，必须是 1-65535 的数字" "$fix"
  value="$(env_value "$key")"
  validate_port "$key" "$value"
}

require_env_uint() {
  local key="$1"
  local desc="$2"
  local fix="${3:-manual}"
  local value

  require_env_nonempty "$key" "$desc" "$fix"
  value="$(env_value "$key")"
  [[ "$value" =~ ^[0-9]+$ ]] || die "node.env 参数 ${key} 必须是数字，收到 '$value'"
}

validate_envsubst_inputs() {
  log "INFO: 检查 envsubst 必需参数：端口 / Reality / HY2 带宽 / HY2 obfs"

  require_env_port "VLESS_PORT"
  require_env_port "HY2_PORT"
  require_env_port "SOCKS5_PORT" "upgrade"

  require_env_uint "HY2_UP_MBPS" "HY2 上行带宽参数"
  require_env_uint "HY2_DOWN_MBPS" "HY2 下行带宽参数"

  require_env_nonempty "REALITY_PRIVATE_KEY" "VLESS Reality private_key"
  require_env_nonempty "REALITY_SHORT_ID" "VLESS Reality short_id"
  require_env_nonempty "REALITY_SNI" "VLESS Reality server_name / handshake server"

  if [[ "${HY2_OBFS:-salamander}" == "salamander" ]]; then
    require_env_nonempty "HY2_OBFS_PASS" "HY2 salamander obfs password"
  fi

  log "INFO: envsubst 必需参数检查通过：VLESS_PORT=${VLESS_PORT} HY2_PORT=${HY2_PORT} SOCKS5_PORT=${SOCKS5_PORT} HY2_UP_MBPS=${HY2_UP_MBPS} HY2_DOWN_MBPS=${HY2_DOWN_MBPS}"
}

validate_domain_strategy "${UPSTREAM_DOMAIN_STRATEGY:-}"
validate_port_policy
validate_envsubst_inputs

if [[ "${UPSTREAM_ENABLED:-0}" == "1" ]]; then
  if [[ -z "${UPSTREAM_NAME:-}" ]]; then
    [[ -n "${UPSTREAM_HOST:-}" && -n "${UPSTREAM_PORT:-}" ]] || die "UPSTREAM_ENABLED=1 且 UPSTREAM_NAME 为空时，HOST/PORT 不能为空"
  fi
fi

if [[ "${UPSTREAM_ENABLED:-0}" != "1" ]] && jq -e 'any(.[]; .egress=="upstream")' "$USERS_FILE" >/dev/null; then
  log "WARN: 存在 egress=upstream 的用户但 UPSTREAM_ENABLED=0，这些用户将直出。"
fi

if [[ "${UPSTREAM_ENABLED:-0}" == "1" ]] \
  && jq -e 'any(.[]; .egress=="upstream")' "$USERS_FILE" >/dev/null \
  && [[ -z "${UPSTREAM_INBOUNDS:-}" ]]; then
  log "WARN: UPSTREAM_INBOUNDS 为空，本次不会生成 upstream 路由规则，egress=upstream 用户会落到 catch-all direct。"
fi

if [[ "${HY2_OBFS:-salamander}" == "salamander" && -z "${HY2_OBFS_PASS:-}" ]]; then
  die "HY2_OBFS=salamander 但 HY2_OBFS_PASS 为空，请先检查 $ENV_FILE"
fi

if [[ "${HY2_RANGE_ENABLED:-0}" == "1" ]]; then
  [[ -n "${HY2_RANGE_TAG:-}" ]] || die "HY2_RANGE_ENABLED=1 但 HY2_RANGE_TAG 为空"
  [[ -n "${HY2_RANGE_OFFSET:-}" ]] || die "HY2_RANGE_ENABLED=1 但 HY2_RANGE_OFFSET 为空"
  validate_offset "$HY2_RANGE_OFFSET"
fi

dbg "读取 inbound overlay"

INBOUND_PATCH_JSON='{"version":2,"base":{"vless":{"tag":"vless-in"},"hy2":{"tag":"hy2-in"},"socks5":{"tag":"socks5-in"}},"patch":{},"delete_fields":{},"delete_inbounds":[],"clones":{}}'

if [[ -f "$INBOUNDS_FILE" ]]; then
  INBOUND_PATCH_JSON="$(
    jq -c '
      def valid_tag($tag):
        ($tag | type) == "string"
        and ($tag | length) > 0
        and ($tag | test("^[A-Za-z0-9_.:-]+$"));

      if type != "object" then
        error("inbounds.json 必须是 object")
      else
        .
      end
      | .version = (.version // 2)
      | .base = (.base // {})
      | .base.vless = (.base.vless // {})
      | .base.hy2 = (.base.hy2 // {})
      | .base.socks5 = (.base.socks5 // {})
      | .base.vless.tag = (.base.vless.tag // "vless-in")
      | .base.hy2.tag = (.base.hy2.tag // "hy2-in")
      | .base.socks5.tag = (.base.socks5.tag // "socks5-in")
      | .patch = (.patch // {})
      | .delete_fields = (.delete_fields // {})
      | .delete_inbounds = (.delete_inbounds // [])
      | .clones = (.clones // {})

      | if (.base | type) != "object" then error(".base 必须是 object") else . end
      | if (valid_tag(.base.vless.tag) | not) then error(".base.vless.tag 非法") else . end
      | if (valid_tag(.base.hy2.tag) | not) then error(".base.hy2.tag 非法") else . end
      | if (valid_tag(.base.socks5.tag) | not) then error(".base.socks5.tag 非法") else . end
      | if ([.base.vless.tag, .base.hy2.tag, .base.socks5.tag] | length) != ([.base.vless.tag, .base.hy2.tag, .base.socks5.tag] | unique | length) then
          error(".base.*.tag 存在重复")
        else
          .
        end
      | if (.patch | type) != "object" then error(".patch 必须是 object") else . end
      | if (.delete_fields | type) != "object" then error(".delete_fields 必须是 object") else . end
      | if (.delete_inbounds | type) != "array" then error(".delete_inbounds 必须是 array") else . end
      | if (.clones | type) != "object" then error(".clones 必须是 object") else . end

      | .delete_inbounds = (
          .delete_inbounds
          | map(tostring)
          | unique
        )

      | .delete_fields = (
          .delete_fields
          | with_entries(
              .value = (
                if (.value | type) == "array" then
                  (.value | map(tostring) | unique)
                else
                  error(".delete_fields." + .key + " 必须是 array")
                end
              )
            )
        )

      | .clones = (
          .clones
          | with_entries(
              .value = (
                if (.value | type) == "object" then
                  .value
                else
                  error(".clones." + .key + " 必须是 object")
                end
              )
            )
        )
    ' "$INBOUNDS_FILE"
  )" || die "$INBOUNDS_FILE 格式错误"
fi

VLESS_TAG="$(jq -r '.base.vless.tag' <<<"$INBOUND_PATCH_JSON")"
HY2_TAG="$(jq -r '.base.hy2.tag' <<<"$INBOUND_PATCH_JSON")"
SOCKS5_TAG="$(jq -r '.base.socks5.tag' <<<"$INBOUND_PATCH_JSON")"
export VLESS_TAG HY2_TAG SOCKS5_TAG
dbg "inbound base tags: vless=$VLESS_TAG hy2=$HY2_TAG socks5=$SOCKS5_TAG"

TMP="$(mktemp)"
TMP2="$(mktemp)"
CHECK_LOG="$(mktemp)"
NFT_BATCH="$(mktemp)"

dbg "envsubst 填标量"
VARS='${SB_ROOT} ${VLESS_TAG} ${HY2_TAG} ${SOCKS5_TAG} ${VLESS_PORT} ${HY2_PORT} ${SOCKS5_PORT} ${REALITY_PRIVATE_KEY} ${REALITY_SHORT_ID} ${REALITY_SNI} ${HY2_UP_MBPS} ${HY2_DOWN_MBPS} ${HY2_OBFS_PASS}'
envsubst "$VARS" < "$TPL" > "$TMP"

if ! jq -e '.inbounds | type == "array"' "$TMP" >/dev/null 2>&1; then
  die "模板经 envsubst 渲染后不是合法 sing-box JSON，或缺 .inbounds[]。请检查 $TPL 以及 node.env 中参与模板渲染的必需参数。临时渲染文件：$TMP"
fi

dbg "读取自定义 outbounds"

CUSTOM_OB_JSON='[]'

if [[ -f "$SB_ROOT/out/outbounds.json" ]]; then
  CUSTOM_OB_JSON="$(jq -c '
    def valid_ds($ds):
      ["prefer_ipv4", "prefer_ipv6", "ipv4_only", "ipv6_only"] | index($ds);

    def normalize_outbounds:
      if type == "array" then
        .
      elif type == "object" then
        [.]
      else
        error("outbounds.json 必须是 object 或 array")
      end;

    normalize_outbounds
    | if any(.[]; type != "object") then
        error("outbounds.json 数组里必须全是 object，不能数组套数组")
      else
        .
      end

    | map(
        if (has("tag") | not) and has("name") then
          . + {tag: .name}
        else
          .
        end
        | del(.name)

        | if has("domain_strategy") then
            .domain_strategy as $ds
            | if ($ds == null or $ds == "" or $ds == "none" or $ds == "as_is") then
                del(.domain_strategy)
              elif valid_ds($ds) then
                .
              else
                error("不支持的 domain_strategy: " + ($ds | tostring))
              end
          else
            .
          end
      )

    | if any(.[]; ((.tag // "") == "")) then
        error("outbounds.json 每个 outbound 都必须有 tag 或 name")
      else
        .
      end

    | if (([.[].tag] | length) != ([.[].tag] | unique | length)) then
        error("outbounds.json 存在重复 tag")
      else
        .
      end
  ' "$SB_ROOT/out/outbounds.json")" || die "$SB_ROOT/out/outbounds.json 格式错误"
fi

dbg "读取 outbound patch overlay"

OUTBOUND_PATCH_JSON='{"version":1,"patch":{}}'
if [[ -f "$OUTBOUND_PATCH_FILE" ]]; then
  OUTBOUND_PATCH_JSON="$(jq -c '
    if type != "object" then error("outbound-patch.json 必须是 object") else . end
    | .version = (.version // 1)
    | .patch = (.patch // {})
    | if (.patch | type) != "object" then error(".patch 必须是 object") else . end
  ' "$OUTBOUND_PATCH_FILE")" || die "$OUTBOUND_PATCH_FILE 格式错误"
fi

dbg "读取 DNS / route overlay"

DNS_JSON='{"enabled":false}'
if [[ -f "$DNS_FILE" ]]; then
  DNS_JSON="$(jq -c '
    if type != "object" then error("dns.json 必须是 object") else . end
    | .enabled  = (.enabled  // false)
    | .servers  = (.servers  // {})
    | .domains  = (.domains  // [])
    | .rules    = (.rules    // [])
    | if (.servers | type) != "object" then error(".servers 必须是 object") else . end
    | if (.domains | type) != "array" then error(".domains 必须是 array") else . end
    | if (.rules | type) != "array" then error(".rules 必须是 array") else . end
    | .domains = (
        .domains
        | map(tostring | ascii_downcase)
        | unique
      )
  ' "$DNS_FILE")" || die "$DNS_FILE 格式错误"
fi

CERT_DOMAIN=""
if [[ -f "$CERT_META_FILE" ]]; then
  CERT_DOMAIN="$(jq -r '(.domain // "") | tostring | ascii_downcase' "$CERT_META_FILE" 2>/dev/null || true)"
fi

ROUTES_JSON='{"enabled":false,"rules":[]}'
if [[ -f "$SB_ROOT/env/routes.json" ]]; then
  ROUTES_JSON="$(jq -c '
    if type != "object" then error("routes.json 必须是 object") else . end
    | .enabled = (.enabled // false)
    | .rules   = (.rules   // [])
  ' "$SB_ROOT/env/routes.json")" || die "$SB_ROOT/env/routes.json 格式错误"
fi

dbg "jq 组装 inbounds / users / upstream / outbounds / rules"

jq \
  --slurpfile users "$USERS_FILE" \
  --argjson inbound_patch "$INBOUND_PATCH_JSON" \
  --argjson custom_ob "$CUSTOM_OB_JSON" \
  --argjson outbound_patch "$OUTBOUND_PATCH_JSON" \
  --argjson dns "$DNS_JSON" \
  --argjson routes "$ROUTES_JSON" \
  --arg up_en  "${UPSTREAM_ENABLED:-0}" \
  --arg up_name "${UPSTREAM_NAME:-}" \
  --arg up_type "${UPSTREAM_TYPE:-socks}" \
  --arg up_host "${UPSTREAM_HOST:-}" \
  --argjson up_port "${UPSTREAM_PORT:-0}" \
  --arg up_user "${UPSTREAM_USER:-}" \
  --arg up_pass "${UPSTREAM_PASS:-}" \
  --arg up_ds "${UPSTREAM_DOMAIN_STRATEGY:-}" \
  --arg up_inbounds "${UPSTREAM_INBOUNDS:-}" \
  --arg hy2_obfs "${HY2_OBFS:-salamander}" \
  --arg hy2_obfs_pass "${HY2_OBFS_PASS:-}" \
  --arg cert_domain "$CERT_DOMAIN" '
  def set_hy2_cert_domain($domain):
    if (.type == "hysteria2") and ($domain != "") and ((.tls.server_name // "") == "") then
      .tls = ((.tls // {}) + {server_name: $domain})
    else
      .
    end;

  def csv_tags($s):
    $s
    | split(",")
    | map(gsub("^\\s+|\\s+$"; ""))
    | map(select(length > 0));

  def deepmerge($a; $b):
    reduce ($b | keys_unsorted[]) as $k ($a;
      .[$k] =
        (
          if ((.[$k] | type) == "object") and (($b[$k] | type) == "object") then
            deepmerge(.[$k]; $b[$k])
          else
            $b[$k]
          end
        )
    );

  def tag_list:
    [.inbounds[]?.tag | select(. != null and . != "")];

  def tag_text:
    (tag_list | join(", "));

  def require_unique_inbound_tags:
    if ((tag_list | length) != (tag_list | unique | length)) then
      error("最终 inbounds 存在重复 tag")
    else
      .
    end;

  def require_all_inbounds_have_tag:
    if any(.inbounds[]?; ((.tag // "") == "")) then
      error("存在没有 tag 的 inbound")
    else
      .
    end;

  # sb-route v1：
  # - outbound 规则：domain/domain-suffix/domain-keyword/domain-regex/ip-cidr -> outbound
  # - action 规则：protocol/network/port/domain... -> action，例如 hijack-dns
  # geosite/geoip 需 rule_set，未启用 → 直接报错
  def route_field($t):
    {
      "domain":"domain","domain-suffix":"domain_suffix","domain-keyword":"domain_keyword",
      "domain-regex":"domain_regex","ip-cidr":"ip_cidr"
    }[$t]
    // error("sb-route: 不支持的 outbound match_type: " + ($t|tostring) + "。v1 仅支持 domain/domain-suffix/domain-keyword/domain-regex/ip-cidr；geosite/geoip 需 rule_set(未启用)");

  def action_match($r):
    if ($r.match_type == "domain") then {domain: [ $r.match_value ]}
    elif ($r.match_type == "domain-suffix") then {domain_suffix: [ $r.match_value ]}
    elif ($r.match_type == "domain-keyword") then {domain_keyword: [ $r.match_value ]}
    elif ($r.match_type == "domain-regex") then {domain_regex: [ $r.match_value ]}
    elif ($r.match_type == "ip-cidr") then {ip_cidr: [ $r.match_value ]}
    elif ($r.match_type == "protocol") then {protocol: $r.match_value}
    elif ($r.match_type == "network") then {network: $r.match_value}
    elif ($r.match_type == "port") then {port: ($r.match_value | tonumber)}
    else error("sb-route: 不支持的 action match_type: " + ($r.match_type|tostring) + "。action 规则支持 domain/domain-suffix/domain-keyword/domain-regex/ip-cidr/protocol/network/port")
    end;

  def route_scope($r):
    (if (($r.auth_user // []) | length) > 0 then {auth_user: $r.auth_user} else {} end)
    + (if (($r.inbound // []) | length) > 0 then {inbound: $r.inbound} else {} end);

  def action_extras($r):
    (if (($r.port // null) != null) then {port: ($r.port | tonumber)} else {} end)
    + (if (($r.network // null) != null) then {network: $r.network} else {} end)
    + (if (($r.protocol // null) != null) then {protocol: $r.protocol} else {} end);

  def is_action_rule($r):
    (($r.kind // "") == "action") or (($r.action // "") != "");

  def compile_action_rules:
    [ ($routes.rules // [])[] as $r
      | select(is_action_rule($r))
      | (action_match($r) + action_extras($r) + {action: $r.action} + route_scope($r))
    ];

  def compile_outbound_rules:
    [ ($routes.rules // [])[] as $r
      | select(is_action_rule($r) | not)
      | { (route_field($r.match_type)): [ $r.match_value ], outbound: $r.outbound }
        + route_scope($r)
    ];

  def insert_after_sniff($rules):
    if (($rules | length) == 0) then
      .
    elif any(.route.rules[]?; (.action? == "sniff")) then
      .route.rules = (
        reduce .route.rules[] as $rr ({done:false, out:[]};
          .out += [$rr]
          | if ((.done | not) and ($rr.action? == "sniff")) then
              .out += $rules | .done = true
            else
              .
            end
        ) | .out
      )
    else
      .route.rules = ($rules + (.route.rules // []))
    end;

  # DNS server 规范化成 sing-box 1.12+ typed server（servers 以 tag 为键的 object）
  def compile_dns_servers:
    [ ($dns.servers // {}) | to_entries[] | .key as $tag | .value as $v |
      if ($v.type // "") == "local" then {type:"local", tag:$tag}
      else {type:$v.type, tag:$tag, server:$v.server}
        + (if ($v.server_port // null) != null then {server_port:$v.server_port} else {} end)
        + (if (($v.type=="https") or ($v.type=="h3")) and (($v.path // "") != "") then {path:$v.path} else {} end)
        + (if ($v.domain_resolver // "") != "" then {domain_resolver:$v.domain_resolver} else {} end)
      end
    ];

  ($users[0]) as $u
  | (csv_tags($up_inbounds)) as $route_inbounds

  | reduce (($inbound_patch.clones // {}) | to_entries[]) as $c (.;
      if (.inbounds | any(.tag == $c.key)) then
        error("clone 目标 inbound 已存在: " + $c.key)
      elif (($c.value.from // "") == "") then
        error("clone " + $c.key + " 缺 from")
      elif (.inbounds | any(.tag == $c.value.from) | not) then
        error("clone 来源 inbound 不存在: " + ($c.value.from // "") + "；可选值：" + tag_text)
      else
        (.inbounds[] | select(.tag == $c.value.from)) as $src
        | .inbounds += [
            (
              $src
              + {tag: $c.key}
              + (
                if ($c.value.listen_port // null) != null then
                  {listen_port: $c.value.listen_port}
                else
                  {}
                end
              )
            )
          ]
      end
    )

  | require_all_inbounds_have_tag
  | require_unique_inbound_tags

  | .inbounds |= map(
      if .type == "vless" then
        .users = [ $u[] | {uuid, name, flow:"xtls-rprx-vision"} ]
      elif .type == "hysteria2" then
        .users = [ $u[] | {name, password} ]
      elif .type == "socks" then
        .users = [ $u[] | {username: .name, password} ]
      else
        .
      end
    )

  | .inbounds |= map(
      if .type == "hysteria2" then
        if $hy2_obfs == "salamander" then
          if $hy2_obfs_pass == "" then
            error("HY2_OBFS=salamander 但 HY2_OBFS_PASS 为空")
          else
            .obfs = {
              type: "salamander",
              password: $hy2_obfs_pass
            }
          end
        elif $hy2_obfs == "plain" or $hy2_obfs == "none" or $hy2_obfs == "" then
          del(.obfs)
        else
          error("HY2_OBFS 只支持 salamander / plain / none")
        end
      else
        .
      end
    )

  | .inbounds |= map(set_hy2_cert_domain($cert_domain))

  | reduce (($inbound_patch.patch // {}) | to_entries[]) as $p (.;
      if (.inbounds | any(.tag == $p.key)) then
        .inbounds |= map(
          if .tag == $p.key then
            deepmerge(.; $p.value)
          else
            .
          end
        )
      else
        error("inbounds.json 修改了不存在的 inbound: " + $p.key + "；可选值：" + tag_text)
      end
    )

  | reduce (($inbound_patch.delete_fields // {}) | to_entries[]) as $d (.;
      if (.inbounds | any(.tag == $d.key)) then
        .inbounds |= map(
          if .tag == $d.key then
            reduce (($d.value // [])[]) as $key (.;
              delpaths([($key | split("."))])
            )
          else
            .
          end
        )
      else
        error("inbounds.json 删除字段引用了不存在的 inbound: " + $d.key + "；可选值：" + tag_text)
      end
    )

  | ($inbound_patch.delete_inbounds // []) as $deleted
  | .inbounds |= map(
      select(.tag as $t | ($deleted | index($t) | not))
    )

  | require_all_inbounds_have_tag
  | require_unique_inbound_tags

  | (tag_list) as $valid_inbounds
  | ([ $route_inbounds[] | select(. as $x | ($valid_inbounds | index($x) | not)) ]) as $bad_inbounds
  | if ($bad_inbounds | length) > 0 then
      error(
        "UPSTREAM_INBOUNDS 包含不存在的 inbound: "
        + ($bad_inbounds | join(", "))
        + "；可选值："
        + ($valid_inbounds | join(", "))
      )
    else
      .
    end

  | if ($custom_ob | length) > 0 then
      .outbounds |= . + $custom_ob
    else
      .
    end

  | ($up_en=="1") as $on
  | ([ $u[] | select(.egress=="upstream") | .name ]) as $upnames
  | ($routes.enabled == true and (($routes.rules // []) | length > 0)) as $r_on
  | ($routes.position // "before-upstream") as $pos

  # sb-route action 规则：插到 sniff 后面，优先于 ip_is_private reject，适合 hijack-dns
  | (if $r_on then insert_after_sniff(compile_action_rules) else . end)

  # sb-route outbound 硬覆盖层：position=before-upstream(默认) 时插在 auth_user upstream 之前
  | (if $r_on and ($pos == "before-upstream") then .route.rules += compile_outbound_rules else . end)

  | if $on and ($upnames | length > 0) and ($route_inbounds | length > 0) then
      if $up_name != "" then
        if (.outbounds | any(.tag == $up_name)) then
          .route.rules += [
            {
              inbound: $route_inbounds,
              auth_user: $upnames,
              outbound: $up_name
            }
          ]
        else
          error("UPSTREAM_NAME=" + $up_name + " 但 outbounds.json / outbounds 里没有同名 tag")
        end
      else
        .outbounds += [
          {
            type: $up_type,
            tag: "upstream",
            server: $up_host,
            server_port: $up_port
          }
          + (
            if $up_ds != "" then
              {domain_strategy: $up_ds}
            else
              {}
            end
          )
          + (
            if $up_user != "" then
              {username: $up_user, password: $up_pass}
            else
              {}
            end
          )
        ]
        | .route.rules += [
            {
              inbound: $route_inbounds,
              auth_user: $upnames,
              outbound: "upstream"
            }
          ]
      end
    else
      .
    end

  # outbound patch overlay：允许修改模板内置 direct / 自定义 outbound / 生成后的 upstream
  | reduce (($outbound_patch.patch // {}) | to_entries[]) as $op (.;
      if (.outbounds | any(.tag == $op.key)) then
        .outbounds |= map(
          if .tag == $op.key then
            deepmerge(.; $op.value)
          else
            .
          end
        )
      else
        error("outbound-patch 引用了不存在的 outbound: " + $op.key + "；可选值：" + ([.outbounds[]?.tag] | join(", ")))
      end
    )

  | if ((.outbounds | map(.tag) | length) != (.outbounds | map(.tag) | unique | length)) then
      error("最终 outbounds 存在重复 tag")
    else
      .
    end

  # sb-route outbound 硬覆盖层：position=after-upstream(高级) 时插在 upstream 之后、final 之前
  | (if $r_on and ($pos == "after-upstream") then .route.rules += compile_outbound_rules else . end)

  | .route.rules += [
      {
        outbound: "direct"
      }
    ]

  # DNS 拼装（dns.json enabled 时；否则完全不加 .dns，行为不变）
  # servers 规范化成 sing-box 1.12+ typed server：{type,tag,server,server_port?,path?,domain_resolver?}
  | if ($dns.enabled == true) then
      .dns = ({ servers: compile_dns_servers, rules: ($dns.rules // []) }
        + (if (($dns.final // "") != "") then {final: $dns.final} else {} end)
        + (if (($dns.strategy // "") != "") then {strategy: $dns.strategy} else {} end))
      | if (($dns.route_default // "") != "") then .route.default_domain_resolver = $dns.route_default else . end
    else
      .
    end
' "$TMP" > "$TMP2" || die "jq 组装失败"

dbg "检查最终 inbound 端口策略"

NON_NUM_PORTS="$(
  jq -r '
    .inbounds[]?
    | select(.listen_port != null)
    | select((.listen_port | tostring | test("^[0-9]+$")) | not)
    | "\(.tag):\(.listen_port)"
  ' "$TMP2"
)"

if [[ -n "$NON_NUM_PORTS" ]]; then
  die "存在非数字 listen_port:
$NON_NUM_PORTS"
fi

BAD_PORTS="$(
  jq -r --argjson min "$INBOUND_PORT_MIN" '
    .inbounds[]?
    | select(.listen_port != null)
    | select((.listen_port | tonumber) < $min)
    | "\(.tag):\(.listen_port)"
  ' "$TMP2"
)"

if [[ -n "$BAD_PORTS" ]]; then
  die "存在低于 INBOUND_PORT_MIN=${INBOUND_PORT_MIN} 的 inbound 端口:
$BAD_PORTS

处理方式示例:
  sb-inbound set vless-in listen_port 40443
  sb-inbound set hy2-in listen_port 40500
  sb-inbound set socks5-in listen_port 40080
  sb-apply"
fi

WARN_PORTS="$(
  jq -r --argjson min "$INBOUND_PORT_MIN" --argjson sug "$INBOUND_PORT_SUGGEST_MIN" '
    .inbounds[]?
    | select(.listen_port != null)
    | select((.listen_port | tonumber) >= $min and (.listen_port | tonumber) < $sug)
    | "\(.tag):\(.listen_port)"
  ' "$TMP2"
)"

if [[ -n "$WARN_PORTS" ]]; then
  log "WARN: 以下 inbound 端口低于建议值 INBOUND_PORT_SUGGEST_MIN=${INBOUND_PORT_SUGGEST_MIN}，建议使用 ${INBOUND_PORT_SUGGEST_MIN}+："
  while read -r line; do
    [[ -n "$line" ]] && log "WARN:   $line"
  done <<< "$WARN_PORTS"
fi

dbg "计算 HY2 range"

HY2_RANGE_ALLOW=""
HY2_RANGE_INFO=""
HY2_RANGE_START=""
HY2_RANGE_END=""
HY2_RANGE_PORT=""
HY2_RANGE_TAG_FINAL=""

if [[ "${HY2_RANGE_ENABLED:-0}" == "1" ]]; then
  command -v nft >/dev/null || die "HY2 range 需要 nftables，请先安装: apt install -y nftables"

  HY2_RANGE_TAG_FINAL="${HY2_RANGE_TAG:-hy2-in}"

  HY2_RANGE_TYPE="$(
    jq -r --arg tag "$HY2_RANGE_TAG_FINAL" '
      .inbounds[]?
      | select(.tag == $tag)
      | .type // empty
    ' "$TMP2" | head -n 1
  )"

  if [[ -z "$HY2_RANGE_TYPE" ]]; then
    AVAIL="$(jq -r '[.inbounds[]?.tag | select(. != null and . != "")] | join(", ")' "$TMP2")"
    die "HY2_RANGE_TAG=$HY2_RANGE_TAG_FINAL 不存在；可选值：${AVAIL:-<none>}"
  fi

  [[ "$HY2_RANGE_TYPE" == "hysteria2" ]] || die "HY2_RANGE_TAG=$HY2_RANGE_TAG_FINAL 不是 hysteria2 inbound，当前 type=$HY2_RANGE_TYPE"

  HY2_RANGE_PORT="$(
    jq -r --arg tag "$HY2_RANGE_TAG_FINAL" '
      .inbounds[]?
      | select(.tag == $tag)
      | .listen_port // empty
    ' "$TMP2" | head -n 1
  )"

  [[ -n "$HY2_RANGE_PORT" ]] || die "HY2_RANGE_TAG=$HY2_RANGE_TAG_FINAL 没有 listen_port"

  validate_port "HY2_RANGE_PORT" "$HY2_RANGE_PORT"
  validate_offset "$HY2_RANGE_OFFSET"

  HALF=$(( HY2_RANGE_OFFSET / 2 ))
  HY2_RANGE_START=$(( HY2_RANGE_PORT - HALF ))
  HY2_RANGE_END=$(( HY2_RANGE_PORT + HALF ))

  (( HY2_RANGE_START >= 1 )) || die "HY2 range 起始端口小于 1：${HY2_RANGE_START}"
  (( HY2_RANGE_END <= 65535 )) || die "HY2 range 结束端口大于 65535：${HY2_RANGE_END}"
  (( HY2_RANGE_START <= HY2_RANGE_END )) || die "HY2 range 非法：${HY2_RANGE_START}-${HY2_RANGE_END}"

  if (( HY2_RANGE_START < INBOUND_PORT_MIN )); then
    SUGGEST_BASE=$(( INBOUND_PORT_MIN + HALF ))
    die "HY2 range 起始端口 ${HY2_RANGE_START} 低于 INBOUND_PORT_MIN=${INBOUND_PORT_MIN}。请提高 ${HY2_RANGE_TAG_FINAL}.listen_port 至少到 ${SUGGEST_BASE}，或降低 HY2_RANGE_OFFSET"
  fi

  if (( HY2_RANGE_START < INBOUND_PORT_SUGGEST_MIN )); then
    SUGGEST_BASE=$(( INBOUND_PORT_SUGGEST_MIN + HALF ))
    log "WARN: HY2 range 起始端口 ${HY2_RANGE_START} 低于建议值 INBOUND_PORT_SUGGEST_MIN=${INBOUND_PORT_SUGGEST_MIN}，建议把 ${HY2_RANGE_TAG_FINAL}.listen_port 调到至少 ${SUGGEST_BASE}"
  fi

  HY2_RANGE_ALLOW="${HY2_RANGE_START}:${HY2_RANGE_END}/udp"
  HY2_RANGE_INFO="${HY2_RANGE_TAG_FINAL}:${HY2_RANGE_START}-${HY2_RANGE_END}->${HY2_RANGE_PORT}/udp"

  log "INFO: HY2 range ${HY2_RANGE_INFO}"
fi

dbg "语法校验（过了才落盘）"

if ! sing-box check -c "$TMP2" 2>&1 | tee "$CHECK_LOG"; then
  die "sing-box check 未通过，已保留临时文件供调试:
  - 渲染后的 config: $TMP2
  - jq 输入 envsubst 后: $TMP
  查看 sing-box 错误信息: cat $CHECK_LOG
  修复后重跑 sb-apply"
fi

CONFIG_CHANGED=1
if [[ -f "$OUT" ]] && cmp -s "$TMP2" "$OUT"; then
  CONFIG_CHANGED=0
fi

if (( CONFIG_CHANGED == 1 )); then
  [[ -f "$OUT" ]] && {
    cp -a "$OUT" "$OUT.bak.$(date +%s)"
    dbg "已备份旧 config"
  }

  install -m 600 "$TMP2" "$OUT"
  log "OK: 已生成 $OUT"
else
  log "OK: config 未变化，跳过落盘与 sing-box restart"
fi

apply_hy2_nft() {
  local table="sb_hy2_range"

  if [[ "${HY2_RANGE_ENABLED:-0}" == "1" && -n "$HY2_RANGE_START" && -n "$HY2_RANGE_END" && -n "$HY2_RANGE_PORT" ]]; then
    : > "$NFT_BATCH"
    if nft list table inet "$table" >/dev/null 2>&1; then
      if nft list chain inet "$table" prerouting >/dev/null 2>&1; then
        {
          echo "flush chain inet $table prerouting"
          echo "delete chain inet $table prerouting"
        } >> "$NFT_BATCH"
      fi
    else
      echo "add table inet $table" >> "$NFT_BATCH"
    fi
    {
      echo "add chain inet $table prerouting { type nat hook prerouting priority dstnat; policy accept; }"
      echo "add rule inet $table prerouting udp dport ${HY2_RANGE_START}-${HY2_RANGE_END} dnat to :${HY2_RANGE_PORT}"
    } >> "$NFT_BATCH"

    nft -f "$NFT_BATCH"

    log "OK: nftables HY2 range dnat 已应用：udp ${HY2_RANGE_START}-${HY2_RANGE_END} -> ${HY2_RANGE_PORT}"
  else
    if command -v nft >/dev/null 2>&1; then
      if nft list table inet "$table" >/dev/null 2>&1; then
        nft delete table inet "$table" || true
        log "OK: 已清理 HY2 range nftables 表"
      fi
    fi
  fi

  return 0
}

if (( CONFIG_CHANGED == 1 )); then
  dbg "重启 sing-box"
  systemctl restart sing-box
  sleep 1
elif ! systemctl is-active --quiet sing-box; then
  dbg "config 未变化但 sing-box 未运行，尝试启动"
  systemctl start sing-box
  sleep 1
else
  dbg "config 未变化且 sing-box 运行中，跳过重启"
fi

systemctl is-active --quiet sing-box || die "sing-box 未起来，看 journalctl -u sing-box -e"

log "OK: sing-box 运行中"

dbg "应用 HY2 range nftables"
apply_hy2_nft

TCP_PORTS="$(
  jq -r '
    .inbounds[]
    | select(.type=="vless" or .type=="trojan" or .type=="vmess" or .type=="socks" or .type=="http")
    | select(.listen_port != null)
    | .listen_port
  ' "$OUT" | sort -u
)"

UDP_PORTS="$(
  jq -r '
    .inbounds[]
    | select(.type=="hysteria2" or .type=="tuic")
    | select(.listen_port != null)
    | .listen_port
  ' "$OUT" | sort -u
)"

SSH_PORT="$(
  ss -tnlpH 2>/dev/null \
    | awk '/sshd/{n=split($4,a,":"); print a[n]}' \
    | grep -E '^[0-9]+$' \
    | sort -u \
    | head -1 \
    || true
)"

SSH_PORT="${SSH_PORT:-22}"

KEEP_HTTP_FOR_CERT=0
if [[ -f "$CERT_META_FILE" ]]; then
  KEEP_HTTP_FOR_CERT=1
elif jq -e '(.domains // []) | length > 0' <<<"$DNS_JSON" >/dev/null; then
  KEEP_HTTP_FOR_CERT=1
fi

dbg "TCP=$TCP_PORTS UDP=$UDP_PORTS SSH=$SSH_PORT EXTRA=${EXTRA_ALLOW:-} PORT_WHITELIST=${PORT_WHITELIST:-} HY2_RANGE=${HY2_RANGE_ALLOW:-} KEEP_HTTP_FOR_CERT=$KEEP_HTTP_FOR_CERT"

declare -A WANT

WANT["${SSH_PORT}/tcp"]=1

if (( KEEP_HTTP_FOR_CERT == 1 )); then
  WANT["80/tcp"]=1
  log "INFO: 检测到证书/域名登记，保留 80/tcp 供 certbot 续期。"
fi

for p in $TCP_PORTS; do
  WANT["${p}/tcp"]=1
done

for p in $UDP_PORTS; do
  WANT["${p}/udp"]=1
done

if [[ -n "${HY2_RANGE_ALLOW:-}" ]]; then
  WANT["$HY2_RANGE_ALLOW"]=1
fi

for e in ${EXTRA_ALLOW:-}; do
  if [[ "$e" =~ ^[0-9]+(:[0-9]+)?/(tcp|udp)$ ]]; then
    WANT["$e"]=1
  else
    log "WARN: 跳过非法 EXTRA_ALLOW 条目 '$e'"
  fi
done

declare -A PORT_WHITELIST_SET
for e in ${PORT_WHITELIST:-}; do
  if [[ "$e" =~ ^[0-9]+(:[0-9]+)?/(tcp|udp)$ ]]; then
    PORT_WHITELIST_SET["$e"]=1
  else
    log "WARN: 跳过非法 PORT_WHITELIST 条目 '$e'"
  fi
done

if ! ufw status 2>/dev/null | grep -q "Status: active"; then
  ufw allow "${SSH_PORT}/tcp" >/dev/null
  ufw --force enable >/dev/null
fi

CUR="$(
  ufw status \
    | awk '/ALLOW/{print $1}' \
    | grep -E '^[0-9]+(:[0-9]+)?/(tcp|udp)$' \
    | sort -u \
    || true
)"

for w in "${!WANT[@]}"; do
  grep -qx "$w" <<<"$CUR" || {
    log "ADD ufw allow $w"
    ufw allow "$w" >/dev/null
  }
done

while read -r c; do
  [[ -z "$c" ]] && continue

  [[ -n "${PORT_WHITELIST_SET[$c]:-}" ]] && {
    dbg "SKIP ufw delete allow $c (在 PORT_WHITELIST 白名单内)"
    continue
  }

  [[ -z "${WANT[$c]:-}" ]] && {
    log "DEL ufw delete allow $c (回收)"
    ufw delete allow "$c" >/dev/null || true
  }
done <<<"$CUR"

ufw reload >/dev/null 2>&1 || true

NUSERS="$(jq 'length' "$USERS_FILE")"
UPSTAT="$([[ "${UPSTREAM_ENABLED:-0}" == "1" ]] && echo on || echo off)"
ALLOWED="$(
  ufw status \
    | awk '/ALLOW/{print $1}' \
    | grep -E '/(tcp|udp)$' \
    | tr '\n' ' ' \
    || true
)"
INBOUND_TAGS="$(jq -r '[.inbounds[]?.tag] | join(",")' "$OUT")"

log "INFO: 部署完成 | users=${NUSERS} upstream=${UPSTAT} | inbounds=${INBOUND_TAGS:-<empty>} | tcp ${TCP_PORTS:-<none>} · udp ${UDP_PORTS:-<none>} | hy2_range=${HY2_RANGE_INFO:-off} | ufw: ${ALLOWED}| 下一步 sb-export"

# 可选快照：sb-apply snapshot 时，apply 全部成功后打一张快照，并只保留最近 10 张
if [[ "$DO_SNAPSHOT" == "1" ]]; then
  SB_BACKUP_BIN=""
  if command -v sb-backup >/dev/null 2>&1; then
    SB_BACKUP_BIN="sb-backup"
  elif [[ -x "$SB_ROOT/bin/sb-backup" ]]; then
    SB_BACKUP_BIN="$SB_ROOT/bin/sb-backup"
  fi
  if [[ -n "$SB_BACKUP_BIN" ]]; then
    if "$SB_BACKUP_BIN" create apply-snapshot >/dev/null; then
      "$SB_BACKUP_BIN" prune 10 >/dev/null || log "WARN: 快照 prune 失败"
      log "OK: 已创建 apply 快照，保留最近 10 张"
    else
      log "WARN: 快照创建失败（不影响本次 apply）"
    fi
  else
    log "WARN: 未安装 sb-backup，跳过快照"
  fi
fi

rm -f "$TMP" "$TMP2" "$CHECK_LOG" "$NFT_BATCH"
dbg "已清理临时文件"
