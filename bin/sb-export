#!/usr/bin/env bash
set -euo pipefail

export SB_ROOT="${SB_ROOT:-$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)}"
OUT_DIR="$SB_ROOT/out"
SUB_DIR="$OUT_DIR/sub"
ENV_FILE="$SB_ROOT/env/node.env"
USERS_FILE="$SB_ROOT/env/users.json"
CONFIG="$SB_ROOT/out/config.json"
CERT_META_FILE="$SB_ROOT/env/cert.json"
DNS_FILE="$SB_ROOT/env/dns.json"

log() { printf '[%s] %s\n' "$(date +%H:%M:%S)" "$*" >&2; }
die() { log "FAIL: $*"; exit 1; }

summary() {
  cat <<'S'
summary:
  sb-export 从最终 out/config.json 读取实际生效的 inbound 和 users，
  为每个用户导出 2 个文件：

    <alias_or_account>_<protocol>.sub
    <alias_or_account>_<protocol>.yaml

  .sub:
    标准 base64 订阅：把所有节点的 vless:// / hysteria2:// / socks5:// 明文 URI
    按行拼好后，对整份文件做 base64 -w0 编码。客户端当订阅链接导入即可。
    想看明文用 sb-show txt。

  .yaml:
    Clash/Mihomo YAML proxies 列表。

  重点：
    - 文件名前缀优先 alias；alias 为空再用 account/name；都为空则省略前缀
    - VLESS Reality/Vision 会导出 tls:true / flow / reality-opts
    - HY2 会导出 obfs + obfs-password
    - HY2 range 会导出到 URI 的 mport 以及 YAML 的 ports / hop-interval
    - upstream/direct 是服务端路由结果，只写到节点名和 x-meta，不伪装成客户端协议字段

  正确顺序：
    sb-apply
    sb-export [tag|protocol|name_or_alias] [tag|protocol|name_or_alias]
    sb-export node|txt|info [tag|protocol|name_or_alias] [...]
S
}

usage() {
  cat <<'U'
usage:
  sb-export [tag|protocol|name_or_alias] [tag|protocol|name_or_alias]
  sb-export node|txt|info [tag|protocol|name_or_alias] [...]

后两个位置参数各自独立识别（顺序不限，重复同类会报错）：
  protocol                     all / vless / hy2 / socks5
  inbound tag                  必须是 out/config.json 里存在的精确 tag
  name_or_alias                users.json 里的 name 或 alias

node/txt/info:
  直接转发给 sb-show，用于 stdout 输出，不写 out/sub 文件。

output:
  <SB_ROOT>/out/sub/<alias_or_account>_<protocol>.sub
  <SB_ROOT>/out/sub/<alias_or_account>_<protocol>.yaml

  prefix 优先级：
    alias 存在 -> alias
    alias 不存在但 name/account 存在 -> name/account
    都不存在 -> 省略前缀，文件名变成 <protocol>.sub / <protocol>.yaml

examples:
  sb-export
  sb-export all
  sb-export vless
  sb-export hy2
  sb-export socks5

  sb-export all AI
  sb-export vless AI
  sb-export hy2-41500 AI
  sb-export node hy2-41500 AI
  sb-export socks5 default

help:
  sb-export help
  sb-export -h
  sb-export --help

notes:
  - .sub 是整文件 base64 标准订阅（protocol:// 明文列表整体 base64 编码）
  - 想看明文 URI 用 sb-show txt
  - node/txt/info 模式等价于 sb-show node/txt/info
  - tag 必须精确匹配 out/config.json 里的 inbound tag，clone 出来的 tag 也支持
  - HY2 range 在 .sub URI 中输出 mport=<range>，在 Clash/Mihomo YAML 中输出 ports/hop-interval
U
}

fail_usage() {
  usage >&2
  die "$1"
}

case "${1:-}" in
  -h|--help|help)
    summary
    echo
    usage
    exit 0
    ;;
esac

if [[ "${1:-}" == "txt" || "${1:-}" == "node" || "${1:-}" == "info" ]]; then
  if show_cmd="$(command -v sb-show 2>/dev/null)" && [[ -x "$show_cmd" ]]; then
    exec "$show_cmd" "$@"
  elif [[ -x "$SB_ROOT/bin/sb-show" ]]; then
    exec "$SB_ROOT/bin/sb-show" "$@"
  elif [[ -r "$SB_ROOT/bin/sb-show" ]]; then
    exec "${BASH:-bash}" "$SB_ROOT/bin/sb-show" "$@"
  else
    die "找不到 sb-show，无法执行 sb-export $1"
  fi
fi

[[ $# -le 2 ]] || fail_usage "参数过多"

[[ -f "$ENV_FILE"   ]] || die "缺 ${ENV_FILE}，先跑 sb-genenv"
[[ -f "$USERS_FILE" ]] || die "缺 ${USERS_FILE}，先跑 sb-genenv"
[[ -f "$CONFIG"     ]] || die "缺 ${CONFIG}，请先跑 sb-apply"

for dep in jq base64 sed grep date mktemp install; do
  command -v "$dep" >/dev/null || die "缺依赖 $dep"
done

jq -e '.inbounds | type == "array"' "$CONFIG" >/dev/null 2>&1 || die "$CONFIG 不是有效 sing-box config，缺 .inbounds[]"
jq -e 'type == "array"' "$USERS_FILE" >/dev/null 2>&1 || die "$USERS_FILE 不是 users array"

set -a
# shellcheck source=/dev/null
source "$ENV_FILE"
set +a

arg1="${1:-}"
arg2="${2:-}"
proto="all"
filter_user=""
filter_tag=""

NODE_NAME="${NODE_NAME:-NODE}"
SERVER_IP="${SERVER_IP:-}"
SERVER_IP6="${SERVER_IP6:-}"
REALITY_PUBLIC_KEY="${REALITY_PUBLIC_KEY:-}"
REALITY_SHORT_ID="${REALITY_SHORT_ID:-}"
REALITY_SNI="${REALITY_SNI:-www.apple.com}"
REALITY_FINGERPRINT="${REALITY_FINGERPRINT:-chrome}"
HY2_SNI="${HY2_SNI:-www.bing.com}"
HY2_RANGE_ENABLED="${HY2_RANGE_ENABLED:-0}"
HY2_RANGE_TAG="${HY2_RANGE_TAG:-}"
HY2_RANGE_OFFSET="${HY2_RANGE_OFFSET:-}"
HY2_RANGE_HOP_INTERVAL="${HY2_RANGE_HOP_INTERVAL:-30}"
UPSTREAM_ENABLED="${UPSTREAM_ENABLED:-0}"
UPSTREAM_NAME="${UPSTREAM_NAME:-}"
MANAGED_DOMAIN=""

if [[ -f "$CERT_META_FILE" ]]; then
  MANAGED_DOMAIN="$(jq -r '(.domain // "") | tostring | ascii_downcase' "$CERT_META_FILE" 2>/dev/null || true)"
fi
if [[ -z "$MANAGED_DOMAIN" && -f "$DNS_FILE" ]]; then
  MANAGED_DOMAIN="$(jq -r '(.domains // [])[0] // "" | tostring | ascii_downcase' "$DNS_FILE" 2>/dev/null || true)"
fi

[[ -n "$SERVER_IP" ]] || die "SERVER_IP 为空，请检查 $ENV_FILE"
[[ -n "$REALITY_PUBLIC_KEY" ]] || die "REALITY_PUBLIC_KEY 为空，请检查 $ENV_FILE"
[[ -n "$REALITY_SHORT_ID" ]] || die "REALITY_SHORT_ID 为空，请检查 $ENV_FILE"

available_protocols_json() {
  jq -c '
    [
      (if any(.inbounds[]?; .type == "vless") then "vless" else empty end),
      (if any(.inbounds[]?; .type == "hysteria2") then "hy2" else empty end),
      (if any(.inbounds[]?; .type == "socks") then "socks5" else empty end)
    ]
  ' "$CONFIG"
}

KNOWN_TAGS_JSON="$(jq -c '[.inbounds[]?.tag] | map(select(. != null and . != ""))' "$CONFIG")"

is_known_tag() {
  jq -e --arg t "$1" 'index($t) != null' <<<"$KNOWN_TAGS_JSON" >/dev/null
}

classify_selector() {
  case "$1" in
    all|vless|hy2|socks5) echo proto ;;
    *) is_known_tag "$1" && echo tag || echo user ;;
  esac
}

proto_for_tag() {
  jq -r --arg t "$1" '
    (.inbounds[]? | select(.tag == $t) |
      (if .type == "vless" then "vless"
       elif .type == "hysteria2" then "hy2"
       elif .type == "socks" then "socks5"
       else "" end)) // ""
  ' "$CONFIG"
}

declare -A SEEN=()

for token in "$arg1" "$arg2"; do
  [[ -n "$token" ]] || continue
  case "$(classify_selector "$token")" in
    proto)
      [[ -z "${SEEN[proto]:-}" ]] || fail_usage "重复指定 protocol：'$token'"
      proto="$token"; SEEN[proto]=1
      ;;
    tag)
      [[ -z "${SEEN[tag]:-}" ]] || fail_usage "重复指定 inbound tag：'$token'"
      filter_tag="$token"; SEEN[tag]=1
      ;;
    user)
      [[ -z "${SEEN[user]:-}" ]] || fail_usage "无法识别的参数组合：'$token'；已有 name/alias '${filter_user}'。如果要指定 tag，请确认 tag 拼写；可用 tag：$(jq -r 'join(", ")' <<<"$KNOWN_TAGS_JSON")"
      filter_user="$token"; SEEN[user]=1
      ;;
  esac
done

if [[ -n "$filter_tag" && "$proto" != "all" ]]; then
  tag_proto="$(proto_for_tag "$filter_tag")"
  [[ "$tag_proto" == "$proto" ]] || fail_usage "inbound tag '$filter_tag' 的协议是 '$tag_proto'，与指定的 protocol '$proto' 不一致"
fi

export_label="$proto"
[[ -n "$filter_tag" ]] && export_label="$filter_tag"

AVAIL_PROTO_JSON="$(available_protocols_json)"
AVAIL_PROTO_TEXT="$(jq -r '(["all"] + .) | join(", ")' <<<"$AVAIL_PROTO_JSON")"

if [[ "$proto" != "all" ]]; then
  if ! jq -e --arg p "$proto" 'index($p) != null' <<<"$AVAIL_PROTO_JSON" >/dev/null; then
    fail_usage "非法协议: '$proto'；可选值：${AVAIL_PROTO_TEXT}"
  fi
fi

USER_COUNT="$(jq --arg f "$filter_user" '
  [
    .[]
    | select($f == "" or (.name // "") == $f or (.alias // "") == $f)
  ]
  | length
' "$USERS_FILE")" || die "读取 users.json 失败"

if [[ "$USER_COUNT" == "0" ]]; then
  USERS_TEXT="$(jq -r '
    [
      .[]
      | ((.name // "") + (if (.alias // "") != "" then "(" + .alias + ")" else "" end))
    ]
    | join(", ")
  ' "$USERS_FILE" 2>/dev/null || true)"
  die "没有匹配用户: '$filter_user'；可选值：${USERS_TEXT:-<none>}"
fi

uri_host() {
  local host="$1"

  if [[ "$host" == *:* && "$host" != \[* ]]; then
    printf '[%s]' "$host"
  else
    printf '%s' "$host"
  fi
}

urlencode() {
  jq -rn --arg v "$1" '$v | @uri'
}

yaml_q() {
  jq -Rn --arg v "$1" '$v'
}

safe_file_part() {
  local v="$1"
  v="$(printf '%s' "$v" | sed -E 's/[[:space:]]+/_/g; s#[/\\:*?"<>|]+#_#g; s/[^A-Za-z0-9._@+-]+/_/g; s/^_+//; s/_+$//')"
  printf '%s' "$v"
}

file_base_for_user() {
  local name="$1"
  local alias="$2"
  local key
  local label

  if [[ -n "$alias" ]]; then
    key="$alias"
  elif [[ -n "$name" ]]; then
    key="$name"
  else
    key=""
  fi

  key="$(safe_file_part "$key")"
  label="$(safe_file_part "$export_label")"
  [[ -n "$label" ]] || label="all"
  if [[ -n "$key" ]]; then
    printf '%s_%s' "$key" "$label"
  else
    printf '%s' "$label"
  fi
}

hy2_range_ports() {
  local tag="$1"
  local port="$2"
  local offset="${HY2_RANGE_OFFSET:-}"
  local half
  local start
  local end

  [[ "${HY2_RANGE_ENABLED:-0}" == "1" ]] || return 0
  [[ -n "${HY2_RANGE_TAG:-}" ]] || return 0
  [[ "$tag" == "$HY2_RANGE_TAG" ]] || return 0
  [[ "$offset" =~ ^[0-9]+$ ]] || return 0
  [[ "$port" =~ ^[0-9]+$ ]] || return 0

  half=$(( offset / 2 ))
  start=$(( port - half ))
  end=$(( port + half ))

  (( start >= 1 && end <= 65535 )) || return 0

  printf '%s-%s' "$start" "$end"
}

# 只判断用户级默认出口，不把 sb-route 的域名/IP 细分规则当成整节点出口。
route_outbound_for_user_tag() {
  local user="$1"
  local tag="$2"

  jq -r --arg u "$user" --arg t "$tag" '
    def str_or_array_has($v; $x):
      if $v == null then false
      elif ($v | type) == "array" then ($v | index($x)) != null
      else ($v == $x)
      end;

    def domainish:
      has("domain") or has("domain_suffix") or has("domain_keyword") or
      has("domain_regex") or has("ip_cidr") or has("rule_set") or
      has("ip_is_private") or has("geoip") or has("geosite");

    [
      .route.rules[]?
      | select(.outbound? != null)
      | select(.auth_user? != null)
      | select(str_or_array_has(.auth_user; $u))
      | select((.inbound? == null) or str_or_array_has(.inbound; $t))
      | select(domainish | not)
      | .outbound
    ][0] // "direct"
  ' "$CONFIG"
}

has_custom_route_rules() {
  jq -e '
    any(.route.rules[]?;
      (.outbound? != null)
      and (
        has("domain") or has("domain_suffix") or has("domain_keyword") or
        has("domain_regex") or has("ip_cidr") or has("rule_set") or
        has("geoip") or has("geosite")
      )
    )
  ' "$CONFIG" >/dev/null 2>&1
}

inbound_user_rows() {
  local username="$1"

  jq -r --arg proto "$proto" --arg tag "$filter_tag" --arg username "$username" '
    def protocol:
      if .type == "vless" then "vless"
      elif .type == "hysteria2" then "hy2"
      elif .type == "socks" then "socks5"
      else empty
      end;

    def first_str($v):
      if $v == null then ""
      elif ($v | type) == "array" then (($v[0] // "") | tostring)
      else ($v | tostring)
      end;

    .inbounds[]? as $in
    | ($in | protocol) as $p
    | select($p != "")
    | select($proto == "all" or $proto == $p)
    | select($tag == "" or (($in.tag // "") == $tag))
    | if $p == "vless" then
        ($in.users[]? | select((.name // "") == $username)) as $u
        | {
            protocol: $p,
            tag: ($in.tag // ""),
            port: (($in.listen_port // "") | tostring),
            sni: ($in.tls.server_name // $in.tls.reality.handshake.server // ""),
            reality_short_id: first_str($in.tls.reality.short_id),
            uuid: ($u.uuid // ""),
            flow: ($u.flow // "xtls-rprx-vision")
          }
      elif $p == "hy2" then
        ($in.users[]? | select((.name // "") == $username)) as $u
        | {
            protocol: $p,
            tag: ($in.tag // ""),
            port: (($in.listen_port // "") | tostring),
            password: ($u.password // ""),
            sni: ($in.tls.server_name // ""),
            obfs_type: ($in.obfs.type // ""),
            obfs_password: ($in.obfs.password // ""),
            up: (($in.up_mbps // "") | tostring),
            down: (($in.down_mbps // "") | tostring)
          }
      elif $p == "socks5" then
        ($in.users[]? | select((.username // .name // "") == $username)) as $u
        | {
            protocol: $p,
            tag: ($in.tag // ""),
            port: (($in.listen_port // "") | tostring),
            socks_username: ($u.username // $u.name // $username),
            socks_password: ($u.password // "")
          }
      else empty end
    | @base64
  ' "$CONFIG"
}

row_get() {
  local json="$1"
  local key="$2"
  jq -r --arg k "$key" '.[$k] // ""' <<<"$json"
}

node_name() {
  local disp="$1"
  local outbound="$2"
  local tag="$3"
  local label="$4"
  local ipver="$5"

  printf '%s-%s-%s-%s-%s' "$NODE_NAME" "$disp" "$outbound" "$tag" "$label-$ipver"
}

vless_uri() {
  local host="$1"
  local port="$2"
  local uuid="$3"
  local disp="$4"
  local tag="$5"
  local ipver="$6"
  local sni="$7"
  local short_id="$8"
  local flow="$9"
  local outbound="${10}"
  local frag
  local q

  [[ -n "$port" ]] || die "vless inbound '$tag' 缺 listen_port"
  [[ -n "$uuid" ]] || die "vless inbound '$tag' 对当前用户缺 uuid"

  [[ -z "$sni" ]] && sni="$REALITY_SNI"
  [[ -z "$short_id" ]] && short_id="$REALITY_SHORT_ID"
  [[ -z "$flow" ]] && flow="xtls-rprx-vision"

  frag="$(urlencode "$(node_name "$disp" "$outbound" "$tag" "Reality" "$ipver")")"
  q="encryption=none&flow=$(urlencode "$flow")&security=reality&sni=$(urlencode "$sni")&fp=$(urlencode "$REALITY_FINGERPRINT")&pbk=$(urlencode "$REALITY_PUBLIC_KEY")&sid=$(urlencode "$short_id")&type=tcp&headerType=none"

  printf 'vless://%s@%s:%s?%s#%s\n' \
    "$(urlencode "$uuid")" \
    "$(uri_host "$host")" \
    "$port" \
    "$q" \
    "$frag"
}

hy2_uri() {
  local host="$1"
  local port="$2"
  local pw="$3"
  local disp="$4"
  local tag="$5"
  local ipver="$6"
  local sni="$7"
  local obfs_type="$8"
  local obfs_pass="$9"
  local ports="${10}"
  local outbound="${11}"
  local frag
  local q

  [[ -n "$port" ]] || die "hy2 inbound '$tag' 缺 listen_port"
  [[ -n "$pw" ]] || die "hy2 inbound '$tag' 对当前用户缺 password"

  [[ -z "$sni" ]] && sni="$HY2_SNI"

  frag="$(urlencode "$(node_name "$disp" "$outbound" "$tag" "Hy2" "$ipver")")"
  q="sni=$(urlencode "$sni")&insecure=1&alpn=h3"

  if [[ -n "$obfs_type" && "$obfs_type" != "plain" && "$obfs_type" != "none" ]]; then
    q="${q}&obfs=$(urlencode "$obfs_type")"
    if [[ -n "$obfs_pass" ]]; then
      q="${q}&obfs-password=$(urlencode "$obfs_pass")"
    fi
  fi

  if [[ -n "$ports" ]]; then
    q="${q}&mport=$(urlencode "$ports")"
  fi

  printf 'hysteria2://%s@%s:%s?%s#%s\n' \
    "$(urlencode "$pw")" \
    "$(uri_host "$host")" \
    "$port" \
    "$q" \
    "$frag"
}

socks5_uri() {
  local host="$1"
  local port="$2"
  local user="$3"
  local pw="$4"
  local disp="$5"
  local tag="$6"
  local ipver="$7"
  local outbound="$8"
  local frag

  [[ -n "$port" ]] || die "socks inbound '$tag' 缺 listen_port"
  [[ -n "$user" ]] || die "socks inbound '$tag' 缺 username"
  [[ -n "$pw" ]] || die "socks inbound '$tag' 缺 password"

  frag="$(urlencode "$(node_name "$disp" "$outbound" "$tag" "Socks5" "$ipver")")"

  printf 'socks5://%s:%s@%s:%s#%s\n' \
    "$(urlencode "$user")" \
    "$(urlencode "$pw")" \
    "$(uri_host "$host")" \
    "$port" \
    "$frag"
}

emit_vless_yaml() {
  local host="$1"
  local port="$2"
  local uuid="$3"
  local disp="$4"
  local tag="$5"
  local ipver="$6"
  local sni="$7"
  local short_id="$8"
  local flow="$9"
  local outbound="${10}"
  local n

  [[ -z "$sni" ]] && sni="$REALITY_SNI"
  [[ -z "$short_id" ]] && short_id="$REALITY_SHORT_ID"
  [[ -z "$flow" ]] && flow="xtls-rprx-vision"

  n="$(node_name "$disp" "$outbound" "$tag" "Reality" "$ipver")"

  cat <<YML
  - name: $(yaml_q "$n")
    type: vless
    server: $(yaml_q "$host")
    port: ${port}
    uuid: $(yaml_q "$uuid")
    network: tcp
    udp: true
    tls: true
    encryption: none
    flow: $(yaml_q "$flow")
    servername: $(yaml_q "$sni")
    client-fingerprint: $(yaml_q "$REALITY_FINGERPRINT")
    reality-opts:
      public-key: $(yaml_q "$REALITY_PUBLIC_KEY")
      short-id: $(yaml_q "$short_id")
    x-sb-outbound: $(yaml_q "$outbound")

YML
}

emit_hy2_yaml() {
  local host="$1"
  local port="$2"
  local pw="$3"
  local disp="$4"
  local tag="$5"
  local ipver="$6"
  local sni="$7"
  local obfs_type="$8"
  local obfs_pass="$9"
  local up="${10}"
  local down="${11}"
  local ports="${12}"
  local outbound="${13}"
  local n

  [[ -z "$sni" ]] && sni="$HY2_SNI"
  n="$(node_name "$disp" "$outbound" "$tag" "Hy2" "$ipver")"

  cat <<YML
  - name: $(yaml_q "$n")
    type: hysteria2
    server: $(yaml_q "$host")
    port: ${port}
YML

  if [[ -n "$ports" ]]; then
    cat <<YML
    ports: $(yaml_q "$ports")
    hop-interval: ${HY2_RANGE_HOP_INTERVAL}
YML
  fi

  cat <<YML
    password: $(yaml_q "$pw")
    sni: $(yaml_q "$sni")
    skip-cert-verify: true
    alpn:
      - h3
YML

  if [[ -n "$obfs_type" && "$obfs_type" != "plain" && "$obfs_type" != "none" ]]; then
    cat <<YML
    obfs: $(yaml_q "$obfs_type")
YML
    if [[ -n "$obfs_pass" ]]; then
      cat <<YML
    obfs-password: $(yaml_q "$obfs_pass")
YML
    fi
  fi

  if [[ -n "$up" ]]; then
    cat <<YML
    up: $(yaml_q "${up} Mbps")
YML
  fi

  if [[ -n "$down" ]]; then
    cat <<YML
    down: $(yaml_q "${down} Mbps")
YML
  fi

  cat <<YML
    x-sb-outbound: $(yaml_q "$outbound")

YML
}

emit_socks5_yaml() {
  local host="$1"
  local port="$2"
  local user="$3"
  local pw="$4"
  local disp="$5"
  local tag="$6"
  local ipver="$7"
  local outbound="$8"
  local n

  n="$(node_name "$disp" "$outbound" "$tag" "Socks5" "$ipver")"

  cat <<YML
  - name: $(yaml_q "$n")
    type: socks5
    server: $(yaml_q "$host")
    port: ${port}
    username: $(yaml_q "$user")
    password: $(yaml_q "$pw")
    udp: true
    x-sb-outbound: $(yaml_q "$outbound")

YML
}

mkdir -p "$SUB_DIR"

N=0
CUSTOM_ROUTES="false"
has_custom_route_rules && CUSTOM_ROUTES="true"

declare -A USED_BASES=()

while IFS=$'\t' read -r name uuid_from_users pw_from_users egress alias; do
  [[ -n "$name" ]] || continue

  N=$((N + 1))

  disp="$alias"
  [[ -z "$disp" ]] && disp="$name"
  [[ -z "$disp" ]] && disp="user"

  file_base="$(file_base_for_user "$name" "$alias")"

  if [[ -n "${USED_BASES[$file_base]:-}" ]]; then
    die "导出文件名冲突: ${file_base}.sub/.yaml 已被用户 ${USED_BASES[$file_base]} 占用；请检查 alias 是否重复"
  fi
  USED_BASES[$file_base]="$name"

  sub_file="$SUB_DIR/${file_base}.sub"
  yaml_file="$SUB_DIR/${file_base}.yaml"

  uris_tmp="$(mktemp)"
  yaml_tmp="$(mktemp)"

  {
    echo "# ${name} (${alias:-no-alias}) $(date -u +%FT%TZ)"
    echo "x-meta:"
    echo "  generated-by: sb-deploy"
    echo "  format: base64-sub-and-mihomo-yaml"
    echo "  protocol-filter: $(yaml_q "$proto")"
    echo "  inbound-tag-filter: $(yaml_q "${filter_tag:-}")"
    echo "  node: $(yaml_q "$NODE_NAME")"
    echo "  domain: $(yaml_q "${MANAGED_DOMAIN:-}")"
    echo "  user: $(yaml_q "$name")"
    echo "  alias: $(yaml_q "${alias:-}")"
    echo "  user-egress: $(yaml_q "${egress:-direct}")"
    echo "  upstream-enabled: $(yaml_q "$UPSTREAM_ENABLED")"
    echo "  upstream-name: $(yaml_q "${UPSTREAM_NAME:-}")"
    echo "  source-config: $(yaml_q "$CONFIG")"
    echo "  hy2-range-enabled: $(yaml_q "$HY2_RANGE_ENABLED")"
    echo "  custom-route-rules: $(yaml_q "$CUSTOM_ROUTES")"
    echo "proxies:"
  } > "$yaml_tmp"

  inbound_user_rows "$name" | while read -r row_b64; do
    [[ -n "$row_b64" ]] || continue
    row_json="$(printf '%s' "$row_b64" | base64 -d)"

    p="$(row_get "$row_json" protocol)"
    tag="$(row_get "$row_json" tag)"
    port="$(row_get "$row_json" port)"
    outbound="$(route_outbound_for_user_tag "$name" "$tag")"

    case "$p" in
      vless)
        sni="$(row_get "$row_json" sni)"
        short_id="$(row_get "$row_json" reality_short_id)"
        vless_uuid="$(row_get "$row_json" uuid)"
        flow="$(row_get "$row_json" flow)"

        vless_uri "$SERVER_IP" "$port" "$vless_uuid" "$disp" "$tag" v4 "$sni" "$short_id" "$flow" "$outbound" >> "$uris_tmp"
        emit_vless_yaml "$SERVER_IP" "$port" "$vless_uuid" "$disp" "$tag" v4 "$sni" "$short_id" "$flow" "$outbound" >> "$yaml_tmp"

        if [[ -n "${SERVER_IP6:-}" ]]; then
          vless_uri "$SERVER_IP6" "$port" "$vless_uuid" "$disp" "$tag" v6 "$sni" "$short_id" "$flow" "$outbound" >> "$uris_tmp"
          emit_vless_yaml "$SERVER_IP6" "$port" "$vless_uuid" "$disp" "$tag" v6 "$sni" "$short_id" "$flow" "$outbound" >> "$yaml_tmp"
        fi
        ;;

      hy2)
        hy2_pw="$(row_get "$row_json" password)"
        hy2_sni="$(row_get "$row_json" sni)"
        obfs_type="$(row_get "$row_json" obfs_type)"
        obfs_pass="$(row_get "$row_json" obfs_password)"
        up="$(row_get "$row_json" up)"
        down="$(row_get "$row_json" down)"
        ports="$(hy2_range_ports "$tag" "$port")"

        hy2_uri "$SERVER_IP" "$port" "$hy2_pw" "$disp" "$tag" v4 "$hy2_sni" "$obfs_type" "$obfs_pass" "$ports" "$outbound" >> "$uris_tmp"
        emit_hy2_yaml "$SERVER_IP" "$port" "$hy2_pw" "$disp" "$tag" v4 "$hy2_sni" "$obfs_type" "$obfs_pass" "$up" "$down" "$ports" "$outbound" >> "$yaml_tmp"

        if [[ -n "${SERVER_IP6:-}" ]]; then
          hy2_uri "$SERVER_IP6" "$port" "$hy2_pw" "$disp" "$tag" v6 "$hy2_sni" "$obfs_type" "$obfs_pass" "$ports" "$outbound" >> "$uris_tmp"
          emit_hy2_yaml "$SERVER_IP6" "$port" "$hy2_pw" "$disp" "$tag" v6 "$hy2_sni" "$obfs_type" "$obfs_pass" "$up" "$down" "$ports" "$outbound" >> "$yaml_tmp"
        fi
        ;;

      socks5)
        socks_user="$(row_get "$row_json" socks_username)"
        socks_pw="$(row_get "$row_json" socks_password)"

        socks5_uri "$SERVER_IP" "$port" "$socks_user" "$socks_pw" "$disp" "$tag" v4 "$outbound" >> "$uris_tmp"
        emit_socks5_yaml "$SERVER_IP" "$port" "$socks_user" "$socks_pw" "$disp" "$tag" v4 "$outbound" >> "$yaml_tmp"

        if [[ -n "${SERVER_IP6:-}" ]]; then
          socks5_uri "$SERVER_IP6" "$port" "$socks_user" "$socks_pw" "$disp" "$tag" v6 "$outbound" >> "$uris_tmp"
          emit_socks5_yaml "$SERVER_IP6" "$port" "$socks_user" "$socks_pw" "$disp" "$tag" v6 "$outbound" >> "$yaml_tmp"
        fi
        ;;
    esac
  done

  if [[ ! -s "$uris_tmp" ]]; then
    rm -f "$uris_tmp" "$yaml_tmp"
    die "没有生成任何节点，protocol=${proto} tag=${filter_tag:-<any>} user=${name}；请确认 sb-apply 后 config.json 里存在该用户"
  fi

  if ! grep -Eq '^(vless|hysteria2|socks5)://' "$uris_tmp"; then
    cat "$uris_tmp" >&2 || true
    rm -f "$uris_tmp" "$yaml_tmp"
    die ".sub 里没有 protocol:// 行，导出异常"
  fi

  base64 -w0 < "$uris_tmp" > "$sub_file"
  chmod 600 "$sub_file"
  install -m 600 "$yaml_tmp" "$yaml_file"

  rm -f "$uris_tmp" "$yaml_tmp"

  log "OK: user ${name}${alias:+ ($alias)} -> ${sub_file#$OUT_DIR/} , ${yaml_file#$OUT_DIR/}"
done < <(
  jq -r --arg filter "$filter_user" '
    .[]
    | select($filter == "" or (.name // "") == $filter or (.alias // "") == $filter)
    | [
        (.name // ""),
        (.uuid // ""),
        (.password // ""),
        (.egress // "direct"),
        (.alias // "")
      ]
    | @tsv
  ' "$USERS_FILE"
)

log "INFO: 订阅导出完成 | users=${N} | protocol=${proto} tag=${filter_tag:-<any>} | 目录 $SUB_DIR/ | $([[ -n "${SERVER_IP6:-}" ]] && echo 'v4+v6' || echo 'v4')"
