#!/usr/bin/env bash
set -euo pipefail

export SB_ROOT="${SB_ROOT:-$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)}"
F="$SB_ROOT/env/dns.json"

log() { printf '[%s] %s\n' "$(date +%H:%M:%S)" "$*" >&2; }
die() { log "FAIL: $*"; exit 1; }

TYPES="local udp tcp tls https h3 quic"

summary() {
  cat <<'S'
summary:
  sb-dns 管理服务端出站 DNS 解析策略（写 env/dns.json，编译由 sb-apply 完成）。

  默认禁用、且只有一个 local server（用系统解析器），不内置任何 DoH。
  高级用户可手动添加 typed server（sing-box 1.12+ 格式）。

  重要（sing-box typed server 语义）：
    - https/h3 用 server(主机) + path(默认 /dns-query)，不是整条 URL
    - server 是域名(非 IP)时，必须指定 --resolver <tag> 来解析这个 DNS server 自己的域名
      （否则 sing-box 会因为无法解析 DNS server 的域名而失败）
S
}

usage() {
  cat <<'U'
usage:
  sb-dns enable | disable
  sb-dns server add <tag> <type> <host|url> [--path P] [--resolver TAG] [--port N]
  sb-dns server rm <tag>
  sb-dns final <tag>
  sb-dns strategy <prefer_ipv4|prefer_ipv6|ipv4_only|ipv6_only|">
  sb-dns route-default <tag>
  sb-dns list
  sb-dns help | -h | --help

type:
  local | udp | tcp | tls | https | h3 | quic
  local 不需要 host；https/h3 可带 --path（默认 /dns-query）

examples:
  sb-dns enable
  sb-dns server add cf   https 1.1.1.1               # IP 型 DoH，无需 resolver
  sb-dns server add cf   https https://1.1.1.1/dns-query   # URL 会自动拆成 server+path
  sb-dns server add ali  https dns.alidns.com --resolver local   # 域名型，必须给 resolver
  sb-dns final cf
  sb-dns strategy prefer_ipv4
  sb-dns route-default local

notes:
  - 改完跑 sb-apply 生效
  - final / route-default 引用的 tag 必须已 server add
  - server 是域名却没 --resolver 会直接报错，不静默接受
U
}

command -v jq >/dev/null || die "缺依赖 jq"
mkdir -p "$SB_ROOT/env"

ensure_file() {
  [[ -f "$F" ]] || printf '{\n  "enabled": false,\n  "servers": { "local": { "type": "local" } },\n  "rules": [],\n  "final": "",\n  "strategy": "",\n  "route_default": ""\n}\n' > "$F"
  local tmp; tmp="$(mktemp)"
  jq '
    (.enabled //= false) | (.servers //= {"local":{"type":"local"}})
    | (.rules //= []) | (.final //= "") | (.strategy //= "") | (.route_default //= "")
  ' "$F" > "$tmp" && install -m 600 "$tmp" "$F"; rm -f "$tmp"
}

write_json() {
  local tmp; tmp="$(mktemp)"; cat > "$tmp"
  jq -e . "$tmp" >/dev/null || { rm -f "$tmp"; die "内部错误：生成了非法 JSON"; }
  install -m 600 "$tmp" "$F"; rm -f "$tmp"
}

is_ip() {
  local h="$1"
  [[ "$h" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]] && return 0   # v4
  [[ "$h" == *:* ]] && return 0                                # v6（含冒号）
  return 1
}

cmd="${1:-}"; [[ $# -gt 0 ]] && shift || true
case "$cmd" in
  -h|--help|help) summary; echo; usage; exit 0 ;;
  summary) summary; exit 0 ;;
esac

ensure_file

case "$cmd" in
  enable)  jq '.enabled=true'  "$F" | write_json; log "OK: dns enabled。跑 sb-apply 生效。" ;;
  disable) jq '.enabled=false' "$F" | write_json; log "OK: dns disabled。跑 sb-apply 生效。" ;;

  server)
    sub="${1:-}"; [[ $# -gt 0 ]] && shift || true
    case "$sub" in
      add)
        tag="${1:-}"; type="${2:-}"; host="${3:-}"
        [[ -n "$tag" && -n "$type" ]] || { usage >&2; die "server add 需要 <tag> <type> [host]"; }
        grep -qw -- "$type" <<<"$TYPES" || die "不支持的 type '$type'。可选：$TYPES"
        [[ $# -ge 2 ]] && shift 2 || shift $#
        [[ "$type" != "local" && -n "$host" ]] && shift || true

        path=""; resolver=""; port=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --path)     shift; path="${1:-}" ;;
            --resolver) shift; resolver="${1:-}" ;;
            --port)     shift; port="${1:-}" ;;
            *) die "未知参数 '$1'" ;;
          esac
          shift || true
        done

        if [[ "$type" == "local" ]]; then
          jq --arg t "$tag" '.servers[$t]={type:"local"}' "$F" | write_json
          log "OK: server $tag=local。跑 sb-apply 生效。"; exit 0
        fi

        [[ -n "$host" ]] || die "type=$type 需要 host（主机名/IP，或 https:// URL）"

        # URL 自动拆 host + path
        if [[ "$host" == *"://"* ]]; then
          rest="${host#*://}"
          hostport="${rest%%/*}"
          urlpath="/${rest#*/}"; [[ "$rest" == "$hostport" ]] && urlpath=""
          host="${hostport%%:*}"; [[ "$hostport" == *:* ]] && port="${port:-${hostport##*:}}"
          [[ -z "$path" && -n "$urlpath" ]] && path="$urlpath"
        fi

        # 域名型必须有 resolver
        if ! is_ip "$host" && [[ -z "$resolver" ]]; then
          die "server '$host' 是域名，必须 --resolver <tag> 指定解析它的 DNS server（否则 sing-box 无法解析该 DNS server 的域名）。IP 型则无需 resolver。"
        fi
        # https/h3 默认 path
        if [[ "$type" == "https" || "$type" == "h3" ]] && [[ -z "$path" ]]; then path="/dns-query"; fi

        jq --arg tag "$tag" --arg ty "$type" --arg sv "$host" --arg pa "$path" --arg rs "$resolver" --arg po "$port" '
          .servers[$tag] = ({type:$ty, server:$sv}
            + (if $po != "" then {server_port:($po|tonumber)} else {} end)
            + (if (($ty=="https") or ($ty=="h3")) and ($pa != "") then {path:$pa} else {} end)
            + (if $rs != "" then {domain_resolver:$rs} else {} end))
        ' "$F" | write_json
        log "OK: server $tag=$type $host$([[ -n "$path" ]] && echo " path=$path")$([[ -n "$resolver" ]] && echo " resolver=$resolver")。跑 sb-apply 生效。"
        ;;
      rm)
        tag="${1:-}"; [[ -n "$tag" ]] || die "server rm 需要 <tag>"
        jq -e --arg t "$tag" '.servers | has($t)' "$F" >/dev/null || die "无此 server: $tag"
        jq --arg t "$tag" 'del(.servers[$t])' "$F" | write_json
        log "OK: 已删 server $tag。跑 sb-apply 生效。"
        ;;
      *) usage >&2; die "server 子命令只支持 add | rm" ;;
    esac
    ;;

  final)
    tag="${1:-}"; [[ -n "$tag" ]] || die "final 需要 <tag>"
    jq -e --arg t "$tag" '.servers | has($t)' "$F" >/dev/null || die "final 引用的 server 不存在: $tag（先 server add）"
    jq --arg t "$tag" '.final=$t' "$F" | write_json; log "OK: final=$tag。跑 sb-apply 生效。"
    ;;

  strategy)
    s="${1:-}"
    case "$s" in prefer_ipv4|prefer_ipv6|ipv4_only|ipv6_only|"") ;; *) die "strategy 只能 prefer_ipv4|prefer_ipv6|ipv4_only|ipv6_only 或空";; esac
    jq --arg s "$s" '.strategy=$s' "$F" | write_json; log "OK: strategy=${s:-<空>}。跑 sb-apply 生效。"
    ;;

  route-default)
    tag="${1:-}"; [[ -n "$tag" ]] || die "route-default 需要 <tag>"
    jq -e --arg t "$tag" '.servers | has($t)' "$F" >/dev/null || die "route-default 引用的 server 不存在: $tag"
    jq --arg t "$tag" '.route_default=$t' "$F" | write_json; log "OK: route_default=$tag。跑 sb-apply 生效。"
    ;;

  list|show)
    printf 'dns: enabled=%s final=%s strategy=%s route_default=%s\n' \
      "$(jq -r '.enabled' "$F")" "$(jq -r '.final // "<空>"' "$F")" "$(jq -r '.strategy // "<空>"' "$F")" "$(jq -r '.route_default // "<空>"' "$F")"
    jq -r '.servers | to_entries[] | "  \(.key): \(.value.type)" +
      (if .value.server then " \(.value.server)" else "" end) +
      (if .value.path then " path=\(.value.path)" else "" end) +
      (if .value.domain_resolver then " resolver=\(.value.domain_resolver)" else "" end)' "$F"
    ;;

  "") usage >&2; die "缺子命令" ;;
  *)  usage >&2; die "未知子命令 '$cmd'" ;;
esac
