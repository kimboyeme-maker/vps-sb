#!/usr/bin/env bash
set -euo pipefail

export SB_ROOT="${SB_ROOT:-$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)}"
F="$SB_ROOT/env/dns.json"

log() { printf '[%s] %s\n' "$(date +%H:%M:%S)" "$*" >&2; }
die() { log "FAIL: $*"; exit 1; }

VALID_STRATEGIES="prefer_ipv4 prefer_ipv6 ipv4_only ipv6_only"
VALID_SERVER_TYPES="local udp tcp tls quic https h3"

summary() {
  cat <<'S'
summary:
  sb-dns 管理 DNS 意图文件 env/dns.json，最终由 sb-apply 编译到 sing-box config。

  存储层：
    env/dns.json:
      {
        enabled,
        servers: { tag -> {type, server, server_port?, path?, domain_resolver?} },
        domains,
        rules,
        final,
        strategy,
        route_default
      }

  最终层：
    - dns.servers / dns.rules / dns.final / dns.strategy 会编译到 top-level dns
    - route_default 会编译到 top-level route.default_domain_resolver

  注意：
    sing-box 最终配置里 dns 和 route 是同层级；
    这里只是把 route.default_domain_resolver 的管理入口放在 sb-dns，
    因为它引用的是 dns server tag。
S
}

usage() {
  cat <<'U'
usage:
  sb-dns status
  sb-dns show
  sb-dns enable
  sb-dns off | disable
  sb-dns reset

  sb-dns server list
  sb-dns server add <tag> <type> [args...]
  sb-dns server del|rm <tag>
  sb-dns server show <tag>

  sb-dns domain list
  sb-dns domain add <domain> [...]
  sb-dns domain rm|del <domain> [...]
  sb-dns domain show <domain>
  sb-dns domain clear

  sb-dns final <server-tag>
  sb-dns final off|clear|del|rm
  sb-dns final show

  sb-dns strategy <prefer_ipv4|prefer_ipv6|ipv4_only|ipv6_only>
  sb-dns strategy off|clear|del|rm
  sb-dns strategy show

  sb-dns route-default show
  sb-dns route-default set <key> <value>
  sb-dns route-default rm|del <key> [value]
  sb-dns route-default off|clear

server types:
  local
  udp   <server> [port]
  tcp   <server> [port]
  tls   <server> [port]
  quic  <server> [port]
  https <server> [port] [path]
  h3    <server> [port] [path]

route-default keys:
  server    DNS server tag，必须已存在于 dns.json 的 servers 里
  strategy  prefer_ipv4 | prefer_ipv6 | ipv4_only | ipv6_only

examples:
  sb-dns enable
  sb-dns server add google tls 8.8.8.8
  sb-dns server add local local
  sb-dns domain add example.com www.example.com

  sb-dns route-default set server google
  sb-dns route-default set strategy prefer_ipv6
  sb-dns route-default show

  sb-dns server add cloudflare https 1.1.1.1 443 /dns-query
  sb-dns final google
  sb-dns strategy prefer_ipv6

notes:
  - route-default 写 env/dns.json 的 route_default object
  - sb-apply 会把它编译成最终 config.route.default_domain_resolver
  - enable/server/final/strategy/route-default 改完跑 sb-apply 生效
  - domain 只是域名登记，供证书/后续规则使用，单独修改不需要 sb-apply
U
}

command -v jq >/dev/null || die "缺依赖 jq"
mkdir -p "$SB_ROOT/env"

ensure_file() {
  if [[ ! -f "$F" ]]; then
    cat > "$F" <<'JSON'
{
  "enabled": false,
  "servers": {},
  "domains": [],
  "rules": []
}
JSON
    chmod 600 "$F"
  fi

  local tmp
  tmp="$(mktemp)"
  jq '
    if type != "object" then error("dns.json 必须是 object") else . end
    | .enabled = (.enabled // false)
    | .servers = (.servers // {})
    | .domains = (.domains // [])
    | .rules = (.rules // [])
    | if (.servers | type) != "object" then error(".servers 必须是 object") else . end
    | if (.domains | type) != "array" then error(".domains 必须是 array") else . end
    | .domains = (.domains | map(tostring | ascii_downcase) | unique)
    | if (.rules | type) != "array" then error(".rules 必须是 array") else . end
  ' "$F" > "$tmp" || { rm -f "$tmp"; die "$F 格式错误"; }

  install -m 600 "$tmp" "$F"
  rm -f "$tmp"
}

write_json() {
  local tmp
  tmp="$(mktemp)"
  cat > "$tmp"
  jq -e . "$tmp" >/dev/null || { rm -f "$tmp"; die "内部错误：生成了非法 JSON"; }
  install -m 600 "$tmp" "$F"
  rm -f "$tmp"
}

validate_strategy() {
  local s="${1:-}"
  [[ -n "$s" ]] || die "缺少 strategy"

  case "$s" in
    prefer_ipv4|prefer_ipv6|ipv4_only|ipv6_only)
      return 0
      ;;
    *)
      die "strategy 仅支持：${VALID_STRATEGIES}，收到 '$s'"
      ;;
  esac
}

validate_server_type() {
  local t="${1:-}"
  [[ -n "$t" ]] || die "缺少 server type"

  case "$t" in
    local|udp|tcp|tls|quic|https|h3)
      return 0
      ;;
    *)
      die "server type 仅支持：${VALID_SERVER_TYPES}，收到 '$t'"
      ;;
  esac
}

validate_port() {
  local port="${1:-}"
  [[ "$port" =~ ^[0-9]+$ ]] || die "port 必须是数字，收到 '$port'"
  (( port >= 1 && port <= 65535 )) || die "port 范围必须是 1-65535，收到 '$port'"
}

normalize_domain() {
  local domain="${1:-}"

  [[ -n "$domain" ]] || die "缺少 domain"
  domain="$(printf '%s' "$domain" | tr '[:upper:]' '[:lower:]')"
  domain="${domain#http://}"
  domain="${domain#https://}"
  domain="${domain%%/*}"
  domain="${domain%%:*}"

  [[ -n "$domain" ]] || die "domain 不能为空"
  [[ "$domain" != .* && "$domain" != *..* && "$domain" != *. ]] || die "非法 domain: '$domain'"
  [[ "$domain" =~ ^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?(\.[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?)+$ ]] || \
    die "非法 domain: '$domain'；请输入类似 example.com 的域名，不要带协议、路径或端口"

  printf '%s' "$domain"
}

domains_args_json() {
  local domains=()
  local d

  [[ $# -gt 0 ]] || die "缺少 domain"
  for d in "$@"; do
    domains+=("$(normalize_domain "$d")")
  done

  printf '%s\n' "${domains[@]}" | jq -Rcs 'split("\n") | map(select(length > 0)) | unique'
}

server_exists() {
  local tag="$1"
  jq -e --arg tag "$tag" '.servers | has($tag)' "$F" >/dev/null
}

server_list_text() {
  jq -r '.servers | keys | if length == 0 then "<none>" else join(", ") end' "$F"
}

require_server() {
  local tag="$1"
  [[ -n "$tag" ]] || die "缺少 server tag"
  if ! server_exists "$tag"; then
    die "DNS server '$tag' 不存在；可选值：$(server_list_text)。先用: sb-dns server add <tag> <type> ..."
  fi
}

normalize_server_json() {
  local tag="$1"
  local type="$2"
  local server="${3:-}"
  local port="${4:-}"
  local path="${5:-}"

  validate_server_type "$type"

  case "$type" in
    local)
      [[ -z "$server" && -z "$port" && -z "$path" ]] || die "local server 不需要额外参数"
      jq -cn --arg type "$type" '{type:$type}'
      ;;

    udp|tcp|tls|quic)
      [[ -n "$server" ]] || die "$type server 需要 <server>"
      if [[ -n "$port" ]]; then
        validate_port "$port"
        jq -cn --arg type "$type" --arg server "$server" --argjson port "$port" \
          '{type:$type, server:$server, server_port:$port}'
      else
        jq -cn --arg type "$type" --arg server "$server" \
          '{type:$type, server:$server}'
      fi
      ;;

    https|h3)
      [[ -n "$server" ]] || die "$type server 需要 <server>"
      [[ -n "$path" ]] || path="/dns-query"
      [[ "$path" == /* ]] || die "path 必须以 / 开头，收到 '$path'"

      if [[ -n "$port" ]]; then
        validate_port "$port"
        jq -cn --arg type "$type" --arg server "$server" --argjson port "$port" --arg path "$path" \
          '{type:$type, server:$server, server_port:$port, path:$path}'
      else
        jq -cn --arg type "$type" --arg server "$server" --arg path "$path" \
          '{type:$type, server:$server, path:$path}'
      fi
      ;;
  esac
}

set_route_default_key() {
  local key="$1"
  local value="$2"

  [[ -n "$key" ]] || die "route-default set 需要 <key> <value>"
  [[ -n "$value" ]] || die "route-default set $key 需要 <value>"

  case "$key" in
    server)
      require_server "$value"
      jq --arg v "$value" '.route_default = (.route_default // {}) | .route_default.server = $v' "$F" | write_json
      log "OK: route_default.server=${value}。跑 sb-apply 生效。"
      ;;
    strategy)
      validate_strategy "$value"
      jq --arg v "$value" '.route_default = (.route_default // {}) | .route_default.strategy = $v' "$F" | write_json
      log "OK: route_default.strategy=${value}。跑 sb-apply 生效。"
      ;;
    *)
      die "route-default 仅支持 key: server / strategy，收到 '$key'"
      ;;
  esac
}

rm_route_default_key() {
  local key="$1"
  local expected="${2:-}"
  [[ -n "$key" ]] || die "route-default rm 需要 <key> [value]"

  case "$key" in
    server|strategy)
      if [[ -n "$expected" ]]; then
        current="$(jq -r --arg k "$key" '.route_default[$k] // ""' "$F")"
        [[ "$current" == "$expected" ]] || die "route_default.$key 当前是 '${current:-<empty>}'，不是 '$expected'，拒绝删除"
      fi

      jq --arg k "$key" '
        if (.route_default // null) == null then
          .
        else
          del(.route_default[$k])
          | if ((.route_default | type) == "object" and (.route_default | length) == 0) then del(.route_default) else . end
        end
      ' "$F" | write_json
      log "OK: 已删除 route_default.${key}。跑 sb-apply 生效。"
      ;;
    *)
      die "route-default rm 仅支持 key: server / strategy，收到 '$key'"
      ;;
  esac
}

cmd="${1:-}"
[[ $# -gt 0 ]] && shift || true

case "$cmd" in
  -h|--help|help)
    summary
    echo
    usage
    exit 0
    ;;
  summary)
    summary
    exit 0
    ;;
esac

ensure_file

case "$cmd" in
  status|show|list)
    jq '.' "$F"
    ;;

  enable)
    jq '.enabled = true' "$F" | write_json
    log "OK: DNS enabled。跑 sb-apply 生效。"
    ;;

  off|disable)
    jq '.enabled = false' "$F" | write_json
    log "OK: DNS disabled。跑 sb-apply 生效。"
    ;;

  reset)
    cat <<'JSON' | write_json
{
  "enabled": false,
  "servers": {},
  "domains": [],
  "rules": []
}
JSON
    log "OK: 已重置 dns.json。跑 sb-apply 生效。"
    ;;

  server)
    sub="${1:-}"
    [[ $# -gt 0 ]] && shift || true

    case "$sub" in
      list)
        jq -r '
          if (.servers | length) == 0 then
            "无 DNS server"
          else
            .servers
            | to_entries[]
            | [
                .key,
                (.value.type // "-"),
                (.value.server // "-"),
                ((.value.server_port // "-") | tostring),
                (.value.path // "-"),
                (if (.value.domain_resolver // null) != null then (.value.domain_resolver | tostring) else "-" end)
              ]
            | @tsv
          end
        ' "$F"
        ;;

      add|set)
        tag="${1:-}"
        type="${2:-}"
        shift 2 || true

        [[ -n "$tag" ]] || die "缺少参数: tag"
        [[ "$tag" =~ ^[A-Za-z0-9._@+-]+$ ]] || die "tag 只能包含 A-Za-z0-9._@+-，收到 '$tag'"
        [[ -n "$type" ]] || die "缺少参数: type"

        server_json="$(normalize_server_json "$tag" "$type" "${1:-}" "${2:-}" "${3:-}")"

        jq --arg tag "$tag" --argjson v "$server_json" '
          .servers[$tag] = $v
        ' "$F" | write_json

        log "OK: DNS server '$tag' 已设置为 type=${type}。跑 sb-apply 生效。"
        ;;

      show)
        tag="${1:-}"
        require_server "$tag"
        jq --arg tag "$tag" '.servers[$tag]' "$F"
        ;;

      del|rm|delete)
        tag="${1:-}"
        require_server "$tag"

        if jq -e --arg tag "$tag" '(.final // "") == $tag' "$F" >/dev/null; then
          die "server '$tag' 正在被 dns.final 引用；先 sb-dns final off"
        fi

        if jq -e --arg tag "$tag" '(.route_default.server? // "") == $tag or ((.route_default | type) == "string" and .route_default == $tag)' "$F" >/dev/null; then
          die "server '$tag' 正在被 route_default 引用；先 sb-dns route-default rm server $tag 或 sb-dns route-default off"
        fi

        jq --arg tag "$tag" 'del(.servers[$tag])' "$F" | write_json
        log "OK: DNS server '$tag' 已删除。跑 sb-apply 生效。"
        ;;

      "")
        usage >&2
        die "缺少 server 子命令"
        ;;

      *)
        usage >&2
        die "未知 server 子命令 '$sub'"
        ;;
    esac
    ;;

  domain|domains)
    sub="${1:-}"
    [[ $# -gt 0 ]] && shift || true

    case "$sub" in
      list)
        jq -r '
          if ((.domains // []) | length) == 0 then
            "无 domain"
          else
            (.domains // [])[]
          end
        ' "$F"
        ;;

      add)
        domains_json="$(domains_args_json "$@")"
        jq --argjson domains "$domains_json" '
          .domains = (((.domains // []) + $domains) | map(tostring | ascii_downcase) | unique)
        ' "$F" | write_json
        log "OK: 已记录 domain: $(jq -r 'join(", ")' <<<"$domains_json")。这是域名登记，不需要 sb-apply。"
        ;;

      show)
        domain="$(normalize_domain "${1:-}")"
        jq --arg domain "$domain" '
          {
            domain: $domain,
            exists: ((.domains // []) | index($domain) != null)
          }
        ' "$F"
        ;;

      rm|del|delete)
        domains_json="$(domains_args_json "$@")"
        jq --argjson domains "$domains_json" '
          .domains = ((.domains // []) | map(select(. as $d | ($domains | index($d) | not))))
        ' "$F" | write_json
        log "OK: 已删除 domain: $(jq -r 'join(", ")' <<<"$domains_json")。这是域名登记，不需要 sb-apply。"
        ;;

      clear|off|none)
        jq '.domains = []' "$F" | write_json
        log "OK: 已清空 domains。这是域名登记，不需要 sb-apply。"
        ;;

      "")
        usage >&2
        die "缺少 domain 子命令"
        ;;

      *)
        usage >&2
        die "未知 domain 子命令 '$sub'"
        ;;
    esac
    ;;

  final)
    sub="${1:-}"
    case "$sub" in
      "")
        usage >&2
        die "final 需要 <server-tag> 或 off/show"
        ;;
      show)
        jq '{final: (.final // null)}' "$F"
        ;;
      off|clear|del|rm|delete|none)
        jq 'del(.final)' "$F" | write_json
        log "OK: 已删除 dns.final。跑 sb-apply 生效。"
        ;;
      *)
        require_server "$sub"
        jq --arg tag "$sub" '.final = $tag' "$F" | write_json
        log "OK: dns.final=${sub}。跑 sb-apply 生效。"
        ;;
    esac
    ;;

  strategy)
    sub="${1:-}"
    case "$sub" in
      "")
        usage >&2
        die "strategy 需要 <strategy> 或 off/show"
        ;;
      show)
        jq '{strategy: (.strategy // null)}' "$F"
        ;;
      off|clear|del|rm|delete|none)
        jq 'del(.strategy)' "$F" | write_json
        log "OK: 已删除 dns.strategy。跑 sb-apply 生效。"
        ;;
      *)
        validate_strategy "$sub"
        jq --arg strategy "$sub" '.strategy = $strategy' "$F" | write_json
        log "OK: dns.strategy=${sub}。跑 sb-apply 生效。"
        ;;
    esac
    ;;

  route-default|route_default|default-domain-resolver|default_domain_resolver)
    sub="${1:-}"
    case "$sub" in
      "")
        usage >&2
        die "route-default 需要 set/rm/show/off"
        ;;

      show)
        jq '{route_default: (.route_default // null), available_servers: (.servers | keys)}' "$F"
        ;;

      off|clear|delete|none)
        jq 'del(.route_default)' "$F" | write_json
        log "OK: 已删除 route_default；最终不会生成 route.default_domain_resolver。跑 sb-apply 生效。"
        ;;

      set)
        key="${2:-}"
        value="${3:-}"
        set_route_default_key "$key" "$value"
        ;;

      rm|del)
        key="${2:-}"
        expected="${3:-}"
        rm_route_default_key "$key" "$expected"
        ;;

      *)
        usage >&2
        die "route-default 子命令只支持 set/rm/del/show/off，收到 '$sub'"
        ;;
    esac
    ;;

  "")
    usage >&2
    die "缺少子命令"
    ;;

  *)
    usage >&2
    die "未知子命令 '$cmd'"
    ;;
esac
