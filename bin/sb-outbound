#!/usr/bin/env bash
set -euo pipefail

export SB_ROOT="${SB_ROOT:-$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)}"
F="$SB_ROOT/out/outbounds.json"
PATCH_F="$SB_ROOT/env/outbound-patch.json"
ENV_FILE="$SB_ROOT/env/node.env"
INBOUNDS_FILE="$SB_ROOT/env/inbounds.json"

log() { printf '[%s] %s\n' "$(date +%H:%M:%S)" "$*" >&2; }
die() { log "FAIL: $*"; exit 1; }

for dep in jq awk; do
  command -v "$dep" >/dev/null || die "缺依赖 $dep"
done

# 探测任意目标主机所在国家二字码，用于 upstream host 的出口地区命名；无 curl/探测失败返回空
detect_region_for_host() {
  local host="$1"
  [[ -n "$host" ]] || { printf ''; return 0; }
  command -v curl >/dev/null 2>&1 || { printf ''; return 0; }

  local c
  c="$(curl -fsS4 --max-time 6 "https://ipapi.co/${host}/country/" 2>/dev/null || true)"
  [[ "$c" =~ ^[A-Za-z]{2}$ ]] || c="$(curl -fsS4 --max-time 6 "http://ip-api.com/line/${host}?fields=countryCode" 2>/dev/null || true)"
  [[ "$c" =~ ^[A-Za-z]{2}$ ]] || c=""

  printf '%s' "${c,,}"
}

# 探测 upstream host 出口地区并写入 UPSTREAM_REGION，探测失败落 unknown（sb-export 只在字段完全缺失时才会现查兜底）
refresh_upstream_region() {
  local host="$1"
  local region

  region="$(detect_region_for_host "$host")"
  [[ -z "$region" ]] && region="unknown"
  set_env "UPSTREAM_REGION" "$region"
  log "OK: UPSTREAM_REGION=${region}"
}

usage() {
  cat >&2 <<U
用法:
  sb-outbound list
  sb-outbound add <name> <type> <参数...>
  sb-outbound del <name>
  sb-outbound show <name>
  sb-outbound set <name> <key> <value>
  sb-outbound reset <name> <key>

  sb-outbound upstream show
  sb-outbound upstream set <key> <value>
  sb-outbound upstream clear <key>
  sb-outbound upstream allow inbounds <inbound[,inbound...]>
  sb-outbound upstream del-inbounds <inbound[,inbound...]>

  sb-outbound direct show
  sb-outbound direct set <key> <value>
  sb-outbound direct rm  <key>

类型-参数:
  socks <host> <port> [user] [pass]
  http  <host> <port> [user] [pass]
  ss    <host> <port> <method> <password>

upstream key:
  name <outbound-name>
  enabled 0|1
  inbounds <inbound[,inbound...]>
  domain_strategy <strategy>
  type socks|http
  host <host>
  port <port>
  user <user>
  pass <pass>
  isp 0|1          订阅节点命名是否带 ISP 段，默认 1；仅影响命名，不影响出站配置

说明：
  UPSTREAM_REGION（upstream 出口地区二字码）在 host/name 变更时自动 geoip 探测并缓存，
  不需要手动设置；探测失败落 unknown。

direct key:
  resolver <dns-server-tag> [strategy]
  domain_strategy <strategy>

named outbound key:
  domain_strategy <strategy>

strategy:
  prefer_ipv4
  prefer_ipv6
  ipv4_only
  ipv6_only

例:
  sb-outbound add isp1 socks proxy.example.com 1080 user pass
  sb-outbound set isp1 domain_strategy ipv4_only
  sb-outbound upstream set name isp1
  sb-outbound upstream set inbounds vless-in,hy2-in
  sb-outbound upstream set domain_strategy ipv4_only
  sb-outbound upstream set enabled 0

  sb-outbound direct set resolver google prefer_ipv6
  sb-outbound direct set domain_strategy ipv4_only
  sb-outbound direct rm resolver

  sb-apply

兼容旧命令仍可解析，但不再推荐：
  enable / disable / inbound / domain / resolver
新用法统一使用 upstream/direct，避免把 outbound 的旧 domain/resolver patch
和当前 upstream/direct patch 混在一起。
U
  exit 1
}

shell_quote() {
  printf '%q' "$1"
}

set_env() {
  local key="$1"
  local value="$2"
  local qvalue
  local tmp

  [[ -f "$ENV_FILE" ]] || die "缺 ${ENV_FILE}，先跑 sb-genenv"

  qvalue="$(shell_quote "$value")"
  tmp="$(mktemp)"

  awk -v k="$key" -v v="$qvalue" '
    BEGIN { done=0 }
    $0 ~ "^" k "=" {
      print k "=" v
      done=1
      next
    }
    { print }
    END {
      if (!done) print k "=" v
    }
  ' "$ENV_FILE" > "$tmp"

  install -m 600 "$tmp" "$ENV_FILE"
  rm -f "$tmp"
}

load_env() {
  [[ -f "$ENV_FILE" ]] || die "缺 ${ENV_FILE}，先跑 sb-genenv"
  set -a
  source "$ENV_FILE"
  set +a
}

ensure_file() {
  mkdir -p "$(dirname "$F")"

  if [[ ! -f "$F" ]]; then
    echo '[]' > "$F"
    chmod 600 "$F"
  fi

  jq -e '
    type == "array"
    and all(.[]; type == "object")
  ' "$F" >/dev/null || die "$F 必须是 array of objects"
}

ensure_patch_file() {
  mkdir -p "$(dirname "$PATCH_F")"

  if [[ ! -f "$PATCH_F" ]]; then
    cat > "$PATCH_F" <<'JSON'
{
  "version": 1,
  "patch": {}
}
JSON
    chmod 600 "$PATCH_F"
  fi

  jq -e '
    type == "object"
    and ((.patch // {}) | type == "object")
  ' "$PATCH_F" >/dev/null || die "$PATCH_F 必须是 object，且 .patch 必须是 object"
}

write_patch_json() {
  local tmp="$1"
  install -m 600 "$tmp" "$PATCH_F"
  rm -f "$tmp"
}

available_inbounds_json() {
  [[ -f "$INBOUNDS_FILE" ]] || die "无法读取可选 inbound：缺 ${INBOUNDS_FILE}，请先跑 sb-genenv upgrade"

  jq -c '
    def valid_tag:
      type == "string" and length > 0;

    if type != "object" then
      error("inbounds.json 必须是 object")
    else
      .
    end
    | .base = (.base // {})
    | .clones = (.clones // {})
    | .delete_inbounds = (.delete_inbounds // [])
    | if (.base | type) != "object" then error(".base 必须是 object") else . end
    | if (.clones | type) != "object" then error(".clones 必须是 object") else . end
    | if (.delete_inbounds | type) != "array" then error(".delete_inbounds 必须是 array") else . end
    | (
        [
          .base.vless.tag?,
          .base.hy2.tag?,
          .base.socks5.tag?
        ]
        | map(select(valid_tag))
      ) as $base
    | ((.clones // {}) | keys) as $clones
    | (.delete_inbounds | map(tostring)) as $deleted
    | ($base + $clones)
    | reduce .[] as $x ([]; if index($x) then . else . + [$x] end)
    | map(select(. as $x | ($deleted | index($x) | not)))
  ' "$INBOUNDS_FILE" || die "$INBOUNDS_FILE 格式错误"
}

available_inbounds_text() {
  available_inbounds_json | jq -r 'join(", ")'
}

inbound_args_json() {
  local raw="$*"
  local item
  local allowed_json
  local allowed_text

  raw="${raw//,/ }"
  [[ -n "${raw// /}" ]] || die "缺少 inbound 参数"

  allowed_json="$(available_inbounds_json)"
  allowed_text="$(jq -r 'join(", ")' <<<"$allowed_json")"

  [[ "$(jq 'length' <<<"$allowed_json")" != "0" ]] || die "没有可选 inbound，无法校验"

  for item in $raw; do
    if ! jq -e --arg t "$item" 'index($t) != null' <<<"$allowed_json" >/dev/null; then
      die "非法 inbound tag: '$item'；可选值：${allowed_text}"
    fi
  done

  printf '%s\n' $raw | jq -R . | jq -s '
    map(select(length > 0))
    | reduce .[] as $x ([]; if index($x) then . else . + [$x] end)
  '
}

ob_exists() {
  local name="$1"
  jq -e --arg n "$name" '
    any(.[]; (.tag // .name) == $n)
  ' "$F" >/dev/null
}

get_ob() {
  local name="$1"
  jq -c --arg n "$name" '
    .[]
    | select((.tag // .name) == $n)
  ' "$F" | head -n 1
}

validate_domain_strategy() {
  local ds="$1"

  case "$ds" in
    prefer_ipv4|prefer_ipv6|ipv4_only|ipv6_only)
      return 0
      ;;
    *)
      die "domain_strategy 仅支持 prefer_ipv4 / prefer_ipv6 / ipv4_only / ipv6_only，收到 '$ds'"
      ;;
  esac
}

write_json() {
  local tmp="$1"
  install -m 600 "$tmp" "$F"
  rm -f "$tmp"
}

csv_join_json() {
  jq -r 'join(",")'
}

current_upstream_inbounds_json() {
  local cur="${UPSTREAM_INBOUNDS:-}"
  jq -nr --arg cur "$cur" '
    $cur
    | split(",")
    | map(gsub("^\\s+|\\s+$"; ""))
    | map(select(length > 0))
  '
}

set_upstream_from_outbound() {
  local name="$1"
  local ob
  local type
  local server
  local port
  local user
  local pass

  [[ -n "$name" ]] || die "upstream set name 需要 <outbound-name>"
  ob_exists "$name" || die "无此 outbound '$name'"

  ob="$(get_ob "$name")"
  type="$(jq -r '.type' <<<"$ob")"
  server="$(jq -r '.server // ""' <<<"$ob")"
  port="$(jq -r '.server_port // ""' <<<"$ob")"
  user="$(jq -r '.username // ""' <<<"$ob")"
  pass="$(jq -r '.password // ""' <<<"$ob")"

  [[ -n "$server" && "$server" != "null" ]] || die "outbound '$name' 缺 server"
  [[ -n "$port" && "$port" != "null" ]] || die "outbound '$name' 缺 server_port"

  set_env "UPSTREAM_ENABLED" "1"
  set_env "UPSTREAM_NAME" "$name"
  set_env "UPSTREAM_TYPE" "$type"
  set_env "UPSTREAM_HOST" "$server"
  set_env "UPSTREAM_PORT" "$port"
  set_env "UPSTREAM_USER" "$user"
  set_env "UPSTREAM_PASS" "$pass"
  refresh_upstream_region "$server"
}

set_upstream_inbounds() {
  local set_json
  local new

  [[ $# -gt 0 ]] || die "upstream set inbounds 需要 <inbound[,inbound...]>"
  set_json="$(inbound_args_json "$@")"
  new="$(csv_join_json <<<"$set_json")"
  set_env "UPSTREAM_INBOUNDS" "$new"
  log "OK: UPSTREAM_INBOUNDS=${new:-<empty>}。跑 sb-apply 生效。"
}

allow_upstream_inbounds() {
  local cur
  local add_json
  local new

  [[ $# -gt 0 ]] || die "upstream allow inbounds 需要 <inbound[,inbound...]>"
  load_env
  cur="${UPSTREAM_INBOUNDS:-}"
  add_json="$(inbound_args_json "$@")"

  new="$(
    jq -nr \
      --arg cur "$cur" \
      --argjson add "$add_json" '
      def splitcsv($s):
        $s
        | split(",")
        | map(gsub("^\\s+|\\s+$"; ""))
        | map(select(length > 0));

      (splitcsv($cur) + $add)
      | reduce .[] as $x ([]; if index($x) then . else . + [$x] end)
      | join(",")
    '
  )"

  set_env "UPSTREAM_INBOUNDS" "$new"
  log "OK: UPSTREAM_INBOUNDS=${new:-<empty>}。跑 sb-apply 生效。"
}

del_upstream_inbounds() {
  local cur
  local del_json
  local new

  [[ $# -gt 0 ]] || die "upstream del inbounds 需要 <inbound[,inbound...]>"
  load_env
  cur="${UPSTREAM_INBOUNDS:-}"
  del_json="$(inbound_args_json "$@")"

  new="$(
    jq -nr \
      --arg cur "$cur" \
      --argjson del "$del_json" '
      def splitcsv($s):
        $s
        | split(",")
        | map(gsub("^\\s+|\\s+$"; ""))
        | map(select(length > 0));

      splitcsv($cur)
      | map(select(. as $x | ($del | index($x) | not)))
      | reduce .[] as $x ([]; if index($x) then . else . + [$x] end)
      | join(",")
    '
  )"

  set_env "UPSTREAM_INBOUNDS" "$new"
  if [[ -z "$new" ]]; then
    log "WARN: UPSTREAM_INBOUNDS 已为空；sb-apply 不会生成 upstream 路由规则。"
  else
    log "OK: UPSTREAM_INBOUNDS=${new}。跑 sb-apply 生效。"
  fi
}

set_upstream_key() {
  local key="$1"
  shift || true
  local value="${1:-}"

  [[ -n "$key" ]] || die "upstream set 需要 <key> <value>"
  [[ $# -gt 0 ]] || die "upstream set $key 需要 <value>"

  case "$key" in
    enabled)
      case "$value" in
        1|true|on|yes) set_env "UPSTREAM_ENABLED" "1" ;;
        0|false|off|no) set_env "UPSTREAM_ENABLED" "0" ;;
        *) die "upstream enabled 只支持 1/0 true/false on/off yes/no，收到 '$value'" ;;
      esac
      log "OK: UPSTREAM_ENABLED=${value}。跑 sb-apply 生效。"
      ;;
    name)
      set_upstream_from_outbound "$value"
      log "OK: 已启用 outbound '$value' 作为 UPSTREAM。跑 sb-apply 生效。"
      ;;
    inbounds|inbound)
      set_upstream_inbounds "$@"
      ;;
    domain_strategy|strategy)
      if [[ "$value" == "off" || "$value" == "clear" || "$value" == "none" ]]; then
        set_env "UPSTREAM_DOMAIN_STRATEGY" ""
      else
        validate_domain_strategy "$value"
        set_env "UPSTREAM_DOMAIN_STRATEGY" "$value"
      fi
      log "OK: UPSTREAM_DOMAIN_STRATEGY=${value}。跑 sb-apply 生效。"
      ;;
    type)
      [[ "$value" == "socks" || "$value" == "http" ]] || die "UPSTREAM_TYPE 仅支持 socks/http，收到 '$value'"
      set_env "UPSTREAM_NAME" ""
      set_env "UPSTREAM_TYPE" "$value"
      log "OK: UPSTREAM_TYPE=${value}。跑 sb-apply 生效。"
      ;;
    host)
      set_env "UPSTREAM_NAME" ""
      set_env "UPSTREAM_HOST" "$value"
      log "OK: UPSTREAM_HOST=${value}。跑 sb-apply 生效。"
      refresh_upstream_region "$value"
      ;;
    port)
      [[ "$value" =~ ^[0-9]+$ ]] || die "UPSTREAM_PORT 必须是数字，收到 '$value'"
      (( value >= 1 && value <= 65535 )) || die "UPSTREAM_PORT 范围必须是 1-65535，收到 '$value'"
      set_env "UPSTREAM_NAME" ""
      set_env "UPSTREAM_PORT" "$value"
      log "OK: UPSTREAM_PORT=${value}。跑 sb-apply 生效。"
      ;;
    user)
      set_env "UPSTREAM_NAME" ""
      set_env "UPSTREAM_USER" "$value"
      log "OK: UPSTREAM_USER=${value}。跑 sb-apply 生效。"
      ;;
    pass|password)
      set_env "UPSTREAM_NAME" ""
      set_env "UPSTREAM_PASS" "$value"
      log "OK: UPSTREAM_PASS=<set>。跑 sb-apply 生效。"
      ;;
    isp)
      case "$value" in
        1|true|on|yes) set_env "UPSTREAM_ISP" "1" ;;
        0|false|off|no) set_env "UPSTREAM_ISP" "0" ;;
        *) die "upstream isp 只支持 1/0，收到 '$value'" ;;
      esac
      log "OK: UPSTREAM_ISP=${value}。仅影响订阅节点命名，无需 sb-apply。"
      ;;
    *)
      die "upstream set 不支持 key '$key'；可选：enabled/name/inbounds/domain_strategy/type/host/port/user/pass/isp"
      ;;
  esac
}

clear_upstream_key() {
  local key="$1"
  [[ -n "$key" ]] || die "upstream clear 需要 <key>"

  case "$key" in
    inbounds|inbound)
      set_env "UPSTREAM_INBOUNDS" ""
      log "OK: UPSTREAM_INBOUNDS=<empty>。跑 sb-apply 生效。"
      ;;
    domain_strategy|strategy)
      set_env "UPSTREAM_DOMAIN_STRATEGY" ""
      log "OK: UPSTREAM_DOMAIN_STRATEGY=<empty>。跑 sb-apply 生效。"
      ;;
    name)
      set_env "UPSTREAM_NAME" ""
      log "OK: UPSTREAM_NAME=<empty>。跑 sb-apply 生效。"
      ;;
    user)
      set_env "UPSTREAM_USER" ""
      log "OK: UPSTREAM_USER=<empty>。跑 sb-apply 生效。"
      ;;
    pass|password)
      set_env "UPSTREAM_PASS" ""
      log "OK: UPSTREAM_PASS=<empty>。跑 sb-apply 生效。"
      ;;
    isp)
      set_env "UPSTREAM_ISP" "1"
      log "OK: UPSTREAM_ISP 已重置为默认值 1。"
      ;;
    *)
      die "upstream clear 不支持 key '$key'；可选：inbounds/domain_strategy/name/user/pass/isp"
      ;;
  esac
}

show_upstream() {
  load_env
  echo "upstream:"
  echo "  enabled=${UPSTREAM_ENABLED:-0}"
  echo "  name=${UPSTREAM_NAME:-}"
  echo "  inbounds=${UPSTREAM_INBOUNDS:-}"
  echo "  domain_strategy=${UPSTREAM_DOMAIN_STRATEGY:-}"
  echo "  type=${UPSTREAM_TYPE:-socks}"
  echo "  host=${UPSTREAM_HOST:-}"
  echo "  port=${UPSTREAM_PORT:-}"
  echo "  user=${UPSTREAM_USER:-}"
  echo "  region=${UPSTREAM_REGION:-<none>} (订阅节点命名用，host 变更时自动探测)"
  echo "  isp=${UPSTREAM_ISP:-1} (1=命名带 ISP 段，0=省略)"
  echo
  echo "available inbounds:"
  available_inbounds_json | jq -r '.[] | "  " + .'
}

set_outbound_patch_key() {
  local tag="$1"
  local key="$2"
  local value="$3"
  local strategy="${4:-}"
  local tmp

  ensure_patch_file

  case "$key" in
    resolver|domain_resolver)
      [[ -n "$value" ]] || die "$tag set resolver 需要 <dns-server-tag> [strategy]"
      if [[ -n "$strategy" ]]; then
        validate_domain_strategy "$strategy"
      fi
      tmp="$(mktemp)"
      jq \
        --arg tag "$tag" \
        --arg server "$value" \
        --arg strategy "$strategy" '
        .version = (.version // 1)
        | .patch = (.patch // {})
        | .patch[$tag] = (.patch[$tag] // {})
        | .patch[$tag].domain_resolver = ({server: $server}
            + (if $strategy != "" then {strategy: $strategy} else {} end))
      ' "$PATCH_F" > "$tmp"
      write_patch_json "$tmp"
      log "OK: 已设置 outbound '$tag' domain_resolver.server=$value${strategy:+ strategy=$strategy}。跑 sb-apply 应用。"
      ;;
    domain_strategy|strategy)
      validate_domain_strategy "$value"
      tmp="$(mktemp)"
      jq \
        --arg tag "$tag" \
        --arg strategy "$value" '
        .version = (.version // 1)
        | .patch = (.patch // {})
        | .patch[$tag] = (.patch[$tag] // {})
        | .patch[$tag].domain_strategy = $strategy
      ' "$PATCH_F" > "$tmp"
      write_patch_json "$tmp"
      log "OK: 已设置 outbound '$tag' domain_strategy=${value}。跑 sb-apply 应用。"
      ;;
    *)
      die "$tag set 不支持 key '$key'；可选：resolver/domain_strategy"
      ;;
  esac
}

set_named_outbound_key() {
  local name="$1"
  local key="$2"
  local value="$3"
  local tmp

  [[ -n "$name" ]] || die "outbound set 需要 <name> <key> <value>"
  [[ -n "$key" ]] || die "outbound set $name 需要 <key> <value>"
  [[ -n "$value" ]] || die "outbound set $name $key 需要 <value>"

  ob_exists "$name" || die "无此 outbound '$name'"

  case "$key" in
    domain_strategy|strategy)
      validate_domain_strategy "$value"
      tmp="$(mktemp)"
      jq --arg n "$name" --arg ds "$value" '
        def norm:
          map(
            if (has("tag") | not) and has("name") then
              . + {tag: .name}
            else
              .
            end
            | del(.name)
          );

        norm
        | map(
            if .tag == $n then
              . + {domain_strategy: $ds}
            else
              .
            end
          )
      ' "$F" > "$tmp"
      write_json "$tmp"
      log "OK: 已设置 outbound '$name' domain_strategy=${value}。pi outbound list 最后一列会显示该值；跑 sb-apply 应用。"
      ;;
    *)
      die "outbound set $name 不支持 key '$key'；可选：domain_strategy"
      ;;
  esac
}

reset_named_outbound_key() {
  local name="$1"
  local key="$2"
  local tmp

  [[ -n "$name" ]] || die "outbound reset 需要 <name> <key>"
  [[ -n "$key" ]] || die "outbound reset $name 需要 <key>"

  ob_exists "$name" || die "无此 outbound '$name'"

  case "$key" in
    domain_strategy|strategy)
      tmp="$(mktemp)"
      jq --arg n "$name" '
        def norm:
          map(
            if (has("tag") | not) and has("name") then
              . + {tag: .name}
            else
              .
            end
            | del(.name)
          );

        norm
        | map(
            if .tag == $n then
              del(.domain_strategy)
            else
              .
            end
          )
      ' "$F" > "$tmp"
      write_json "$tmp"
      log "OK: 已删除 outbound '$name' 的 domain_strategy。pi outbound list 最后一列会回到 '-'；跑 sb-apply 应用。"
      ;;
    *)
      die "outbound reset $name 不支持 key '$key'；可选：domain_strategy"
      ;;
  esac
}

rm_outbound_patch_key() {
  local tag="$1"
  local key="$2"
  local field
  local tmp

  ensure_patch_file
  [[ -n "$key" ]] || die "$tag rm 需要 <key>"

  case "$key" in
    resolver|domain_resolver) field="domain_resolver" ;;
    domain_strategy|strategy) field="domain_strategy" ;;
    *) die "$tag rm 不支持 key '$key'；可选：resolver/domain_strategy" ;;
  esac

  tmp="$(mktemp)"
  jq --arg tag "$tag" --arg field "$field" '
    .version = (.version // 1)
    | .patch = (.patch // {})
    | if (.patch[$tag] // null) == null then
        .
      else
        del(.patch[$tag][$field])
        | if ((.patch[$tag] // {}) | length) == 0 then del(.patch[$tag]) else . end
      end
  ' "$PATCH_F" > "$tmp"

  write_patch_json "$tmp"
  log "OK: 已删除 outbound '$tag' 的 $field patch。跑 sb-apply 应用。"
}

ensure_file

cmd="${1:-}"
shift || true

case "$cmd" in
  list)
    jq -r '
      if length == 0 then
        "无自定义 outbound"
      else
        .[]
        | [
            (.tag // .name // "-"),
            (.type // "-"),
            ((.server // "-") + ":" + ((.server_port // "-") | tostring)),
            (.domain_strategy // "-")
          ]
        | @tsv
      end
    ' "$F"
    ;;

  add)
    name="${1:-}"
    type="${2:-}"

    [[ -n "$name" ]] || die "缺少参数: name"
    [[ -n "$type" ]] || die "缺少参数: type (socks|http|ss)"
    [[ "$type" == "socks" || "$type" == "http" || "$type" == "ss" ]] || die "type 仅支持 socks|http|ss，收到 '$type'"

    ob_exists "$name" && die "outbound '$name' 已存在"

    case "$type" in
      socks|http)
        server="${3:-}"
        port="${4:-}"
        user="${5:-}"
        pass="${6:-}"

        [[ -n "$server" ]] || die "缺少参数: $type 需要 <host>"
        [[ -n "$port" ]] || die "缺少参数: $type 需要 <port>"
        [[ "$port" =~ ^[0-9]+$ ]] || die "参数错误: port 必须是数字，收到 '$port'"
        (( port >= 1 && port <= 65535 )) || die "参数错误: port 范围必须是 1-65535，收到 '$port'"

        tmp="$(mktemp)"
        jq \
          --arg n "$name" \
          --arg t "$type" \
          --arg s "$server" \
          --argjson p "$port" \
          --arg u "$user" \
          --arg pw "$pass" '
          def norm:
            map(
              if (has("tag") | not) and has("name") then
                . + {tag: .name}
              else
                .
              end
              | del(.name)
            );

          norm
          | . += [
              {
                tag: $n,
                type: $t,
                server: $s,
                server_port: ($p | tonumber)
              }
              + (
                if $u != "" then
                  {username: $u, password: $pw}
                else
                  {}
                end
              )
            ]
        ' "$F" > "$tmp"
        ;;

      ss)
        server="${3:-}"
        port="${4:-}"
        method="${5:-}"
        password="${6:-}"

        [[ -n "$server" ]] || die "缺少参数: ss 需要 <host>"
        [[ -n "$port" ]] || die "缺少参数: ss 需要 <port>"
        [[ -n "$method" ]] || die "缺少参数: ss 需要 <method>"
        [[ -n "$password" ]] || die "缺少参数: ss 需要 <password>"
        [[ "$port" =~ ^[0-9]+$ ]] || die "参数错误: port 必须是数字，收到 '$port'"
        (( port >= 1 && port <= 65535 )) || die "参数错误: port 范围必须是 1-65535，收到 '$port'"

        tmp="$(mktemp)"
        jq \
          --arg n "$name" \
          --arg s "$server" \
          --argjson p "$port" \
          --arg m "$method" \
          --arg pw "$password" '
          def norm:
            map(
              if (has("tag") | not) and has("name") then
                . + {tag: .name}
              else
                .
              end
              | del(.name)
            );

          norm
          | . += [
              {
                tag: $n,
                type: "shadowsocks",
                server: $s,
                server_port: ($p | tonumber),
                method: $m,
                password: $pw
              }
            ]
        ' "$F" > "$tmp"
        ;;
    esac

    write_json "$tmp"
    log "OK: 已加 outbound $name ($type)。跑 sb-apply 应用。"
    ;;

  del)
    name="${1:-}"
    [[ -n "$name" ]] || die "缺少参数: name"

    ob_exists "$name" || die "无此 outbound '$name'"

    tmp="$(mktemp)"
    jq --arg n "$name" '
      def norm:
        map(
          if (has("tag") | not) and has("name") then
            . + {tag: .name}
          else
            .
          end
          | del(.name)
        );

      norm
      | map(select(.tag != $n))
    ' "$F" > "$tmp"

    write_json "$tmp"
    log "OK: 已删 outbound ${name}。跑 sb-apply 应用。"

    load_env
    if [[ "${UPSTREAM_NAME:-}" == "$name" ]]; then
      set_env "UPSTREAM_ENABLED" "0"
      set_env "UPSTREAM_NAME" ""
      set_env "UPSTREAM_HOST" ""
      set_env "UPSTREAM_PORT" ""
      set_env "UPSTREAM_USER" ""
      set_env "UPSTREAM_PASS" ""
      set_env "UPSTREAM_REGION" ""
      set_env "UPSTREAM_ISP" "1"
      log "WARN: 被删 outbound '${name}' 正是当前 upstream，已清空 UPSTREAM_* 并禁用 upstream。跑 sb-apply 生效。"
    fi
    ;;

  show)
    name="${1:-}"
    [[ -n "$name" ]] || die "缺少参数: name"

    ob_exists "$name" || die "无此 outbound '$name'"
    get_ob "$name" | jq '.'
    ;;

  set)
    set_named_outbound_key "${1:-}" "${2:-}" "${3:-}"
    ;;

  reset)
    reset_named_outbound_key "${1:-}" "${2:-}"
    ;;

  enable)
    [[ -f "$ENV_FILE" ]] || die "缺 ${ENV_FILE}，先跑 sb-genenv"

    name="${1:-}"

    if [[ -z "$name" ]]; then
      count="$(jq 'length' "$F")"

      if [[ "$count" == "0" ]]; then
        die "没有任何 outbound，请先 sb-outbound add"
      elif [[ "$count" == "1" ]]; then
        name="$(jq -r '.[0].tag // .[0].name' "$F")"
        log "INFO: 未指定 name，自动选择唯一 outbound: $name"
      else
        die "存在多个 outbound，请明确指定：sb-outbound upstream set name <name>"
      fi
    fi

    ob_exists "$name" || die "无此 outbound '$name'"

    set_upstream_from_outbound "$name"

    log "OK: 已启用 outbound '$name' 作为 UPSTREAM。"
    log "INFO: egress=upstream 的用户会走 ${name}；跑 sb-apply 生效。"
    ;;

  disable)
    [[ -f "$ENV_FILE" ]] || die "缺 ${ENV_FILE}，先跑 sb-genenv"

    set_env "UPSTREAM_ENABLED" "0"

    log "OK: 已禁用 UPSTREAM（UPSTREAM_ENABLED=0）。跑 sb-apply 生效。"
    ;;

  upstream)
    sub="${1:-}"
    shift || true

    case "$sub" in
      show|list)
        show_upstream
        ;;
      set)
        key="${1:-}"
        shift || true
        set_upstream_key "$key" "$@"
        ;;
      clear|rm|del)
        clear_upstream_key "${1:-}"
        ;;
      allow)
        key="${1:-}"
        shift || true
        [[ "$key" == "inbounds" || "$key" == "inbound" ]] || die "用法: sb-outbound upstream allow inbounds <tag[,tag...]>"
        allow_upstream_inbounds "$@"
        ;;
      del-inbounds|rm-inbounds)
        del_upstream_inbounds "$@"
        ;;
      *)
        usage
        ;;
    esac
    ;;

  direct)
    sub="${1:-}"
    shift || true

    case "$sub" in
      show|list)
        ensure_patch_file
        jq '{tag:"direct", patch:(.patch.direct // {})}' "$PATCH_F"
        ;;
      set)
        key="${1:-}"
        value="${2:-}"
        strategy="${3:-}"
        [[ -n "$key" && -n "$value" ]] || die "用法: sb-outbound direct set <resolver|domain_strategy> <value> [strategy]"
        set_outbound_patch_key "direct" "$key" "$value" "$strategy"
        ;;
      rm|del|clear)
        rm_outbound_patch_key "direct" "${1:-}"
        ;;
      *)
        usage
        ;;
    esac
    ;;

  domain)
    sub="${1:-}"
    shift || true

    case "$sub" in
      list)
        jq -r '
          if length == 0 then
            "无自定义 outbound"
          else
            .[]
            | [
                (.tag // .name // "-"),
                (.server // "-"),
                ((.server_port // "-") | tostring),
                (.domain_strategy // "<unset>")
              ]
            | @tsv
          end
        ' "$F"
        ;;

      show)
        name="${1:-}"
        [[ -n "$name" ]] || die "缺少参数: name"

        ob_exists "$name" || die "无此 outbound '$name'"

        get_ob "$name" | jq '{
          tag: (.tag // .name),
          server,
          server_port,
          domain_strategy: (.domain_strategy // null)
        }'
        ;;

      set)
        name="${1:-}"
        strategy="${2:-ipv4_only}"

        [[ -n "$name" ]] || die "缺少参数: name"
        validate_domain_strategy "$strategy"

        ob_exists "$name" || die "无此 outbound '$name'"

        tmp="$(mktemp)"
        jq --arg n "$name" --arg ds "$strategy" '
          def norm:
            map(
              if (has("tag") | not) and has("name") then
                . + {tag: .name}
              else
                .
              end
              | del(.name)
            );

          norm
          | map(
              if .tag == $n then
                . + {domain_strategy: $ds}
              else
                .
              end
            )
        ' "$F" > "$tmp"

        write_json "$tmp"
        log "OK: 已设置 outbound '$name' domain_strategy=${strategy}。跑 sb-apply 应用。"
        ;;

      del|rm)
        name="${1:-}"
        [[ -n "$name" ]] || die "缺少参数: name"

        ob_exists "$name" || die "无此 outbound '$name'"

        tmp="$(mktemp)"
        jq --arg n "$name" '
          def norm:
            map(
              if (has("tag") | not) and has("name") then
                . + {tag: .name}
              else
                .
              end
              | del(.name)
            );

          norm
          | map(
              if .tag == $n then
                del(.domain_strategy)
              else
                .
              end
            )
        ' "$F" > "$tmp"

        write_json "$tmp"
        log "OK: 已删除 outbound '$name' 的 domain_strategy。跑 sb-apply 应用。"
        ;;

      *)
        usage
        ;;
    esac
    ;;


  resolver)
    sub="${1:-}"
    shift || true

    ensure_patch_file

    case "$sub" in
      list)
        jq -r '
          (.patch // {})
          | [to_entries[] | select(.value.domain_resolver? != null)] as $items
          | if ($items | length) == 0 then
              "无 outbound resolver patch"
            else
              $items[]
              | [
                  .key,
                  (.value.domain_resolver.server // "-"),
                  (.value.domain_resolver.strategy // "-")
                ]
              | @tsv
            end
        ' "$PATCH_F"
        ;;

      show)
        name="${1:-}"
        [[ -n "$name" ]] || die "缺少参数: outbound-tag"

        jq --arg n "$name" '
          {
            tag: $n,
            domain_resolver: ((.patch[$n].domain_resolver) // null)
          }
        ' "$PATCH_F"
        ;;

      set)
        name="${1:-}"
        server="${2:-}"
        strategy="${3:-}"

        [[ -n "$name" ]] || die "缺少参数: outbound-tag，例如 direct"
        [[ -n "$server" ]] || die "缺少参数: dns-server-tag，例如 google"
        if [[ -n "$strategy" ]]; then
          validate_domain_strategy "$strategy"
        fi

        tmp="$(mktemp)"
        jq \
          --arg n "$name" \
          --arg server "$server" \
          --arg strategy "$strategy" '
          .version = (.version // 1)
          | .patch = (.patch // {})
          | .patch[$n] = (.patch[$n] // {})
          | .patch[$n].domain_resolver = ({server: $server}
              + (if $strategy != "" then {strategy: $strategy} else {} end))
        ' "$PATCH_F" > "$tmp"

        write_patch_json "$tmp"
        log "OK: 已设置 outbound '$name' domain_resolver.server=$server${strategy:+ strategy=$strategy}。跑 sb-apply 应用。"
        ;;

      del|rm)
        name="${1:-}"
        [[ -n "$name" ]] || die "缺少参数: outbound-tag"

        tmp="$(mktemp)"
        jq --arg n "$name" '
          .version = (.version // 1)
          | .patch = (.patch // {})
          | if (.patch[$n] // null) == null then
              .
            else
              del(.patch[$n].domain_resolver)
              | if ((.patch[$n] // {}) | length) == 0 then del(.patch[$n]) else . end
            end
        ' "$PATCH_F" > "$tmp"

        write_patch_json "$tmp"
        log "OK: 已删除 outbound '$name' 的 domain_resolver patch。跑 sb-apply 应用。"
        ;;

      *)
        usage
        ;;
    esac
    ;;

  inbound)
    sub="${1:-}"
    shift || true

    case "$sub" in
      list)
        load_env
        echo "current:"
        if [[ -z "${UPSTREAM_INBOUNDS:-}" ]]; then
          echo "  <empty>"
        else
          echo "$UPSTREAM_INBOUNDS" | tr ',' '\n' | sed 's/^/  /'
        fi
        echo "available:"
        available_inbounds_json | jq -r '.[] | "  " + .'
        ;;

      allow)
        [[ $# -gt 0 ]] || die "缺少 inbound 参数，例如: sb-outbound upstream allow inbounds vless-in,hy2-in"
        load_env

        cur="${UPSTREAM_INBOUNDS:-}"
        add_json="$(inbound_args_json "$@")"

        new="$(
          jq -nr \
            --arg cur "$cur" \
            --argjson add "$add_json" '
            def splitcsv($s):
              $s
              | split(",")
              | map(gsub("^\\s+|\\s+$"; ""))
              | map(select(length > 0));

            (splitcsv($cur) + $add)
            | reduce .[] as $x ([]; if index($x) then . else . + [$x] end)
            | join(",")
          '
        )"

        set_env "UPSTREAM_INBOUNDS" "$new"
        log "OK: UPSTREAM_INBOUNDS=${new:-<empty>}。跑 sb-apply 生效。"
        ;;

      set)
        [[ $# -gt 0 ]] || die "缺少 inbound 参数，例如: sb-outbound upstream set inbounds vless-in,hy2-in"

        set_json="$(inbound_args_json "$@")"
        new="$(jq -r 'join(",")' <<<"$set_json")"

        set_env "UPSTREAM_INBOUNDS" "$new"
        log "OK: UPSTREAM_INBOUNDS=${new:-<empty>}。跑 sb-apply 生效。"
        ;;

      del|rm)
        [[ $# -gt 0 ]] || die "缺少 inbound 参数，例如: sb-outbound upstream del-inbounds hy2-in"
        load_env

        cur="${UPSTREAM_INBOUNDS:-}"
        del_json="$(inbound_args_json "$@")"

        new="$(
          jq -nr \
            --arg cur "$cur" \
            --argjson del "$del_json" '
            def splitcsv($s):
              $s
              | split(",")
              | map(gsub("^\\s+|\\s+$"; ""))
              | map(select(length > 0));

            splitcsv($cur)
            | map(select(. as $x | ($del | index($x) | not)))
            | reduce .[] as $x ([]; if index($x) then . else . + [$x] end)
            | join(",")
          '
        )"

        set_env "UPSTREAM_INBOUNDS" "$new"

        if [[ -z "$new" ]]; then
          log "WARN: UPSTREAM_INBOUNDS 已为空；sb-apply 不会生成 upstream 路由规则。"
        else
          log "OK: UPSTREAM_INBOUNDS=${new}。跑 sb-apply 生效。"
        fi
        ;;

      clear)
        set_env "UPSTREAM_INBOUNDS" ""
        log "OK: UPSTREAM_INBOUNDS=<empty>。跑 sb-apply 生效。"
        ;;

      *)
        usage
        ;;
    esac
    ;;

  *)
    usage
    ;;
esac
