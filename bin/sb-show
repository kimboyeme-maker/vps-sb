#!/usr/bin/env bash
set -euo pipefail

export SB_ROOT="${SB_ROOT:-$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)}"
ENV_FILE="$SB_ROOT/env/node.env"
USERS_FILE="$SB_ROOT/env/users.json"
CONFIG="$SB_ROOT/out/config.json"
CERT_META_FILE="$SB_ROOT/env/cert.json"
DNS_FILE="$SB_ROOT/env/dns.json"

# geoip 探测源，按顺序依次尝试；仅在 NODE_COUNTRY 缺失时用作兜底
GEOIP_SOURCES=(
  "https://ipapi.co/country/"
  "http://ip-api.com/line/?fields=countryCode"
  "https://ifconfig.co/country-iso"
)

log() { printf '[%s] %s\n' "$(date +%H:%M:%S)" "$*" >&2; }
die() { log "FAIL: $*"; exit 1; }

# 依次尝试 GEOIP_SOURCES 探测本机所在国家二字码（小写），全部失败返回空；无 curl 时静默跳过
detect_country() {
  command -v curl >/dev/null 2>&1 || { printf ''; return 0; }

  local src
  local c

  for src in "${GEOIP_SOURCES[@]}"; do
    c="$(curl -fsS4 --max-time 6 "$src" 2>/dev/null || true)"
    if [[ "$c" =~ ^[A-Za-z]{2}$ ]]; then
      printf '%s' "${c,,}"
      return 0
    fi
  done

  printf ''
}

summary() {
  cat <<'S'
summary:
  sb-show 从最终 /opt/sb-deploy/out/config.json 读取实际生效的 inbound，
  再结合 env/node.env 和 users.json 输出分享链接或 JSON 节点数据。

  重点：
    - 不再读取模板推测端口
    - 不再自己理解 sb-inbound 的 set/rm/clone/delete
    - 所有 inbound 改动先由 sb-apply 编译进 out/config.json
    - clone 出来的 vless/hy2/socks5 inbound 会自动出现在 sb-show 输出里
    - 不使用 TSV 承载空字段，避免 HY2 的 obfs/up/down 字段错位

  改完配置后的正确顺序：
    sb-inbound ...
    sb-apply
    sb-show ...
S
}

usage() {
  cat <<'U'
usage:
  sb-show [mode] [tag|protocol|name_or_alias] [tag|protocol|name_or_alias]

mode:
  txt                         明文分享链接输出，默认；只输出 vless:// / hysteria2:// / socks5:// 行
  node                        JSON 节点数据输出
  info                        人类可读信息输出：server / protocols / inbounds / hy2 range

后两个位置参数各自独立识别（顺序不限，重复同类会报错）：
  protocol                     all / vless / hy2 / socks5
  inbound tag                  必须是 out/config.json 里存在的精确 tag（如 hy2-in、hy2-41500）
  name_or_alias                users.json 里的 name 或 alias

  识别优先级：protocol 关键字 > 精确 tag 命中 > 当作 name/alias

examples:
  sb-show
  sb-show txt
  sb-show node

  sb-show txt all
  sb-show txt vless
  sb-show txt hy2
  sb-show txt socks5

  sb-show node all
  sb-show node vless
  sb-show node hy2
  sb-show node socks5

  sb-show txt default
  sb-show txt all default
  sb-show txt vless default
  sb-show node socks5 default
  sb-show info

  sb-show txt hy2-41500              只看某个具体 hy2 clone inbound
  sb-show txt hy2-41500 default       tag + 用户 一起过滤
  sb-show node vless-in

help:
  sb-show help
  sb-show -h
  sb-show --help

notes:
  - protocol 不传时默认 all
  - name_or_alias 不传时输出所有用户
  - sb-show txt default 会自动识别 default 为用户过滤，不再误判为协议
  - protocol 传错会提示当前可选值
  - 当前可选协议来自 out/config.json 里的 inbounds
  - tag 必须精确匹配 out/config.json 里的 inbound tag，clone 出来的 tag 也支持
  - tag 与 protocol 同时给出但类型不一致会直接报错
  - txt 模式只输出明文 URI 行，不输出标题、注释、分隔符
  - HY2 range 会在 info/node 输出里显示 ports；txt URI 会带 mport=<range>
  - URI authority 仍保留 HY2 主监听端口作兼容字段；端口跳跃范围由 mport 表达
U
}

fail_usage() {
  usage >&2
  die "$1"
}

case "${1:-}" in
  -h|--help|help)
    summary
    echo
    usage
    exit 0
    ;;
esac

[[ $# -le 3 ]] || fail_usage "参数过多"

[[ -f "$ENV_FILE"   ]] || die "缺 ${ENV_FILE}，先跑 sb-genenv"
[[ -f "$USERS_FILE" ]] || die "缺 ${USERS_FILE}，先跑 sb-genenv"
[[ -f "$CONFIG"     ]] || die "缺 ${CONFIG}，请先跑 sb-apply"

for dep in jq base64; do
  command -v "$dep" >/dev/null || die "缺依赖 $dep"
done

jq -e '.inbounds | type == "array"' "$CONFIG" >/dev/null 2>&1 || die "$CONFIG 不是有效 sing-box config，缺 .inbounds[]"
jq -e 'type == "array"' "$USERS_FILE" >/dev/null 2>&1 || die "$USERS_FILE 不是 users array"

set -a
# shellcheck source=/dev/null
source "$ENV_FILE"
set +a

mode="${1:-txt}"
arg2="${2:-}"
arg3="${3:-}"
proto="all"
filter_user=""
filter_tag=""

case "$mode" in
  txt|node|info)
    ;;
  *)
    fail_usage "非法 mode: '$mode'；可选值：txt, node, info"
    ;;
esac

KNOWN_TAGS_JSON="$(jq -c '[.inbounds[]?.tag] | map(select(. != null and . != ""))' "$CONFIG")"

is_known_tag() {
  jq -e --arg t "$1" 'index($t) != null' <<<"$KNOWN_TAGS_JSON" >/dev/null
}

classify_selector() {
  case "$1" in
    all|vless|hy2|socks5) echo proto ;;
    *) is_known_tag "$1" && echo tag || echo user ;;
  esac
}

declare -A SEEN=()

for token in "$arg2" "$arg3"; do
  [[ -n "$token" ]] || continue
  case "$(classify_selector "$token")" in
    proto)
      [[ -z "${SEEN[proto]:-}" ]] || fail_usage "重复指定 protocol：'$token'"
      proto="$token"; SEEN[proto]=1
      ;;
    tag)
      [[ -z "${SEEN[tag]:-}" ]] || fail_usage "重复指定 inbound tag：'$token'"
      filter_tag="$token"; SEEN[tag]=1
      ;;
    user)
      [[ -z "${SEEN[user]:-}" ]] || fail_usage "无法识别的参数组合：'$token'；已有 name/alias '${filter_user}'。如果要指定 tag，请确认 tag 拼写；可用 tag：$(jq -r 'join(", ")' <<<"$KNOWN_TAGS_JSON")"
      filter_user="$token"; SEEN[user]=1
      ;;
  esac
done

if [[ -n "$filter_tag" && "$proto" != "all" ]]; then
  tag_proto="$(
    jq -r --arg t "$filter_tag" '
      (.inbounds[]? | select(.tag == $t) |
        (if .type == "vless" then "vless"
         elif .type == "hysteria2" then "hy2"
         elif .type == "socks" then "socks5"
         else "" end)) // ""
    ' "$CONFIG"
  )"
  [[ "$tag_proto" == "$proto" ]] || fail_usage "inbound tag '$filter_tag' 的协议是 '$tag_proto'，与指定的 protocol '$proto' 不一致"
fi

NODE_NAME="${NODE_NAME:-NODE}"
NODE_COUNTRY="${NODE_COUNTRY:-}"
if [[ -z "$NODE_COUNTRY" ]]; then
  NODE_COUNTRY="$(detect_country)"
  [[ -z "$NODE_COUNTRY" ]] && NODE_COUNTRY="unknown"
fi
SERVER_IP="${SERVER_IP:-}"
SERVER_IP6="${SERVER_IP6:-}"
REALITY_PUBLIC_KEY="${REALITY_PUBLIC_KEY:-}"
REALITY_SHORT_ID="${REALITY_SHORT_ID:-}"
REALITY_SNI="${REALITY_SNI:-www.apple.com}"
REALITY_FINGERPRINT="${REALITY_FINGERPRINT:-chrome}"
HY2_SNI="${HY2_SNI:-www.bing.com}"
HY2_RANGE_ENABLED="${HY2_RANGE_ENABLED:-0}"
HY2_RANGE_TAG="${HY2_RANGE_TAG:-}"
HY2_RANGE_OFFSET="${HY2_RANGE_OFFSET:-}"
HY2_RANGE_HOP_INTERVAL="${HY2_RANGE_HOP_INTERVAL:-30}"
MANAGED_DOMAIN=""

if [[ -f "$CERT_META_FILE" ]]; then
  MANAGED_DOMAIN="$(jq -r '(.domain // "") | tostring | ascii_downcase' "$CERT_META_FILE" 2>/dev/null || true)"
fi
if [[ -z "$MANAGED_DOMAIN" && -f "$DNS_FILE" ]]; then
  MANAGED_DOMAIN="$(jq -r '(.domains // [])[0] // "" | tostring | ascii_downcase' "$DNS_FILE" 2>/dev/null || true)"
fi

# 枚举节点连接地址：v4 / v6(可选) / 域名(可选)，tab 分隔 <host>\t<label>
addr_list() {
  printf '%s\t%s\n' "$SERVER_IP" "v4"
  [[ -n "${SERVER_IP6:-}" ]] && printf '%s\t%s\n' "$SERVER_IP6" "v6"
  [[ -n "$MANAGED_DOMAIN" ]] && printf '%s\t%s\n' "$MANAGED_DOMAIN" "domain"
  return 0
}

# 本次输出范围内，各协议出现的 inbound 数量（用于判断节点名用协议名还是 tag 消歧）
PROTO_COUNTS_JSON="$(
  jq -r --arg proto "$proto" --arg tag "$filter_tag" '
    def protocol:
      if .type == "vless" then "vless"
      elif .type == "hysteria2" then "hy2"
      elif .type == "socks" then "socks5"
      else empty end;
    [
      .inbounds[]? | protocol as $p
      | select($p != "")
      | select($proto == "all" or $proto == $p)
      | select($tag == "" or (.tag // "") == $tag)
      | $p
    ] | group_by(.) | map({key: .[0], value: length}) | from_entries
  ' "$CONFIG"
)"

# 同协议只有一个 inbound 时用协议名，出现多个 inbound 时改用 tag 消歧
tag_or_type_label() {
  local proto_key="$1"
  local tag="$2"
  local count
  count="$(jq -r --arg p "$proto_key" '.[$p] // 0' <<<"$PROTO_COUNTS_JSON")"
  if [[ "$count" -gt 1 ]]; then
    printf '%s' "$tag"
  else
    printf '%s' "$proto_key"
  fi
}

# 无域名：v4 裸名，v6 加 -v6；有域名：域名裸名，v4/v6 都加后缀
addr_suffix() {
  local addr_label="$1"
  if [[ -z "$MANAGED_DOMAIN" ]]; then
    case "$addr_label" in
      v6) printf -- '-v6' ;;
      *) printf '' ;;
    esac
  else
    case "$addr_label" in
      v4) printf -- '-v4' ;;
      v6) printf -- '-v6' ;;
      *) printf '' ;;
    esac
  fi
}

[[ -n "$SERVER_IP" ]] || die "SERVER_IP 为空，请检查 $ENV_FILE"
[[ -n "$REALITY_PUBLIC_KEY" ]] || die "REALITY_PUBLIC_KEY 为空，请检查 $ENV_FILE"
[[ -n "$REALITY_SHORT_ID" ]] || die "REALITY_SHORT_ID 为空，请检查 $ENV_FILE"

available_protocols_json() {
  jq -c '
    [
      (if any(.inbounds[]?; .type == "vless") then "vless" else empty end),
      (if any(.inbounds[]?; .type == "hysteria2") then "hy2" else empty end),
      (if any(.inbounds[]?; .type == "socks") then "socks5" else empty end)
    ]
  ' "$CONFIG"
}

AVAIL_PROTO_JSON="$(available_protocols_json)"
AVAIL_PROTO_TEXT="$(jq -r '(["all"] + .) | join(", ")' <<<"$AVAIL_PROTO_JSON")"

if [[ "$proto" != "all" ]]; then
  if ! jq -e --arg p "$proto" 'index($p) != null' <<<"$AVAIL_PROTO_JSON" >/dev/null; then
    fail_usage "非法协议: '$proto'；可选值：${AVAIL_PROTO_TEXT}"
  fi
fi

USER_COUNT="$(
  jq --arg f "$filter_user" '
    [
      .[]
      | select($f == "" or (.name // "") == $f or (.alias // "") == $f)
    ]
    | length
  ' "$USERS_FILE"
)"

if [[ "$USER_COUNT" == "0" ]]; then
  USERS_TEXT="$(
    jq -r '
      [
        .[]
        | ((.name // "") + (if (.alias // "") != "" then "(" + .alias + ")" else "" end))
      ]
      | join(", ")
    ' "$USERS_FILE"
  )"
  die "没有匹配用户: '$filter_user'；可选用户：${USERS_TEXT:-<none>}；可选 tag：$(jq -r 'join(", ")' <<<"$KNOWN_TAGS_JSON")"
fi

uri_host() {
  local host="$1"

  if [[ "$host" == *:* && "$host" != \[* ]]; then
    printf '[%s]' "$host"
  else
    printf '%s' "$host"
  fi
}

urlencode() {
  jq -rn --arg v "$1" '$v | @uri'
}

json_get() {
  local json="$1"
  local key="$2"
  jq -r --arg k "$key" '.[$k] // ""' <<<"$json"
}

json_get_num_or_empty() {
  local json="$1"
  local key="$2"
  jq -r --arg k "$key" 'if .[$k] == null then "" else (.[$k] | tostring) end' <<<"$json"
}

hy2_range_ports() {
  local tag="$1"
  local port="$2"
  local offset="${HY2_RANGE_OFFSET:-}"
  local half
  local start
  local end

  [[ "${HY2_RANGE_ENABLED:-0}" == "1" ]] || return 0
  [[ -n "${HY2_RANGE_TAG:-}" ]] || return 0
  [[ "$tag" == "$HY2_RANGE_TAG" ]] || return 0
  [[ "$offset" =~ ^[0-9]+$ ]] || return 0
  [[ "$port" =~ ^[0-9]+$ ]] || return 0

  half=$(( offset / 2 ))
  start=$(( port - half ))
  end=$(( port + half ))

  (( start >= 1 && end <= 65535 )) || return 0

  printf '%s-%s' "$start" "$end"
}

# 每行输出一个 base64(JSON object)。不要用 @tsv：Bash read 会折叠连续 IFS 空白，空字段会导致列错位。
inbound_rows() {
  jq -r --arg proto "$proto" --arg tag "$filter_tag" '
    def protocol:
      if .type == "vless" then "vless"
      elif .type == "hysteria2" then "hy2"
      elif .type == "socks" then "socks5"
      else empty
      end;

    def first_str($v):
      if $v == null then ""
      elif ($v | type) == "array" then (($v[0] // "") | tostring)
      else ($v | tostring)
      end;

    .inbounds[]?
    | protocol as $p
    | select($p != "")
    | select($proto == "all" or $proto == $p)
    | select($tag == "" or (.tag // "") == $tag)
    | {
        protocol: $p,
        tag: (.tag // ""),
        port: (.listen_port // null),
        sni: (.tls.server_name // .tls.reality.handshake.server // ""),
        reality_short_id: first_str(.tls.reality.short_id),
        obfs_type: (.obfs.type // ""),
        obfs_password: (.obfs.password // ""),
        up_mbps: (.up_mbps // null),
        down_mbps: (.down_mbps // null)
      }
    | @base64
  ' "$CONFIG"
}

user_rows() {
  jq -r --arg filter "$filter_user" '
    .[]
    | select($filter == "" or (.name // "") == $filter or (.alias // "") == $filter)
    | {
        name: (.name // ""),
        egress: (.egress // "direct"),
        uuid: (.uuid // ""),
        password: (.password // ""),
        alias: (.alias // "")
      }
    | @base64
  ' "$USERS_FILE"
}

vless_uri() {
  local host="$1"
  local port="$2"
  local uuid="$3"
  local name="$4"
  local sni="$5"
  local short_id="$6"
  local frag
  local q

  [[ -n "$port" && "$port" != "null" ]] || die "vless inbound 缺 listen_port"
  [[ -n "$uuid" ]] || die "vless 用户缺 uuid"

  [[ -z "$sni" ]] && sni="$REALITY_SNI"
  [[ -z "$short_id" ]] && short_id="$REALITY_SHORT_ID"

  frag="$(urlencode "$name")"
  q="encryption=none&flow=xtls-rprx-vision&security=reality&sni=$(urlencode "$sni")&fp=$(urlencode "$REALITY_FINGERPRINT")&pbk=$(urlencode "$REALITY_PUBLIC_KEY")&sid=$(urlencode "$short_id")&type=tcp"

  printf 'vless://%s@%s:%s?%s#%s\n' \
    "$(urlencode "$uuid")" \
    "$(uri_host "$host")" \
    "$port" \
    "$q" \
    "$frag"
}

hy2_uri() {
  local host="$1"
  local port="$2"
  local pw="$3"
  local name="$4"
  local addr_label="$5"
  local sni="$6"
  local obfs_type="$7"
  local obfs_pass="$8"
  local ports="$9"
  local frag
  local q

  [[ -n "$port" && "$port" != "null" ]] || die "hy2 inbound 缺 listen_port"
  [[ -n "$pw" ]] || die "hy2 用户缺 password"

  [[ -z "$sni" ]] && sni="$HY2_SNI"

  local insecure=1
  [[ "$addr_label" == "domain" ]] && insecure=0

  frag="$(urlencode "$name")"
  q="sni=$(urlencode "$sni")&insecure=${insecure}&alpn=h3"

  if [[ -n "$obfs_type" && "$obfs_type" != "plain" && "$obfs_type" != "none" ]]; then
    q="${q}&obfs=$(urlencode "$obfs_type")"
    if [[ -n "$obfs_pass" ]]; then
      q="${q}&obfs-password=$(urlencode "$obfs_pass")"
    fi
  fi

  if [[ -n "$ports" ]]; then
    q="${q}&mport=$(urlencode "$ports")"
  fi

  printf 'hysteria2://%s@%s:%s?%s#%s\n' \
    "$(urlencode "$pw")" \
    "$(uri_host "$host")" \
    "$port" \
    "$q" \
    "$frag"

}

socks5_uri() {
  local host="$1"
  local port="$2"
  local user="$3"
  local pw="$4"
  local name="$5"
  local frag

  [[ -n "$port" && "$port" != "null" ]] || die "socks inbound 缺 listen_port"
  [[ -n "$user" ]] || die "socks 用户名为空"
  [[ -n "$pw" ]] || die "socks 用户 '$user' 缺 password"

  frag="$(urlencode "$name")"

  printf 'socks5://%s:%s@%s:%s#%s\n' \
    "$(urlencode "$user")" \
    "$(urlencode "$pw")" \
    "$(uri_host "$host")" \
    "$port" \
    "$frag"
}

case "$mode" in
  txt)
    user_rows | while read -r user_b64; do
      [[ -n "$user_b64" ]] || continue
      user_json="$(printf '%s' "$user_b64" | base64 -d)"
      name="$(json_get "$user_json" name)"
      uuid="$(json_get "$user_json" uuid)"
      pw="$(json_get "$user_json" password)"
      alias="$(json_get "$user_json" alias)"
      disp="$alias"
      [[ -z "$disp" ]] && disp="$name"

      inbound_rows | while read -r row_b64; do
        [[ -n "$row_b64" ]] || continue
        row_json="$(printf '%s' "$row_b64" | base64 -d)"
        p="$(json_get "$row_json" protocol)"
        tag="$(json_get "$row_json" tag)"
        port="$(json_get_num_or_empty "$row_json" port)"
        sni="$(json_get "$row_json" sni)"
        short_id="$(json_get "$row_json" reality_short_id)"
        obfs_type="$(json_get "$row_json" obfs_type)"
        obfs_pass="$(json_get "$row_json" obfs_password)"
        ports=""

        if [[ "$p" == "hy2" ]]; then
          ports="$(hy2_range_ports "$tag" "$port")"
        fi

        case "$p" in
          vless|hy2|socks5) ;;
          *) continue ;;
        esac

        proto_label="$(tag_or_type_label "$p" "$tag")"

        echo "# ── ${disp} · ${p} · ${tag} ──"
        while IFS=$'\t' read -r host addr_label; do
          [[ -n "$host" ]] || continue
          nodename="${NODE_COUNTRY}-${proto_label}$(addr_suffix "$addr_label")"
          case "$p" in
            vless)
              vless_uri "$host" "$port" "$uuid" "$nodename" "$sni" "$short_id"
              ;;
            hy2)
              hy2_uri "$host" "$port" "$pw" "$nodename" "$addr_label" "$sni" "$obfs_type" "$obfs_pass" "$ports"
              ;;
            socks5)
              socks5_uri "$host" "$port" "$name" "$pw" "$nodename"
              ;;
          esac
        done < <(addr_list)
        echo
      done
    done
    ;;

  info)
    echo "Server v4: ${SERVER_IP}  v6: ${SERVER_IP6:-<none>}"
    echo "Domain: ${MANAGED_DOMAIN:-<none>}"
    echo "Protocols: ${AVAIL_PROTO_TEXT}"
    echo "HY2 range: enabled=${HY2_RANGE_ENABLED:-0} tag=${HY2_RANGE_TAG:-<none>} offset=${HY2_RANGE_OFFSET:-<none>} hop=${HY2_RANGE_HOP_INTERVAL}"
    echo
    echo "Inbounds:"
    inbound_rows | while read -r row_b64; do
      [[ -n "$row_b64" ]] || continue
      row_json="$(printf '%s' "$row_b64" | base64 -d)"
      p="$(json_get "$row_json" protocol)"
      tag="$(json_get "$row_json" tag)"
      port="$(json_get_num_or_empty "$row_json" port)"
      ports=""
      if [[ "$p" == "hy2" ]]; then
        ports="$(hy2_range_ports "$tag" "$port")"
      fi
      echo "  ${p} ${tag} port=${port}${ports:+ ports=$ports}"
    done
    echo
    echo "Users:"
    user_rows | while read -r user_b64; do
      [[ -n "$user_b64" ]] || continue
      user_json="$(printf '%s' "$user_b64" | base64 -d)"
      name="$(json_get "$user_json" name)"
      eg="$(json_get "$user_json" egress)"
      alias="$(json_get "$user_json" alias)"
      echo "  ${name} egress=${eg}${alias:+ alias=$alias}"
    done
    ;;

  node)
    INB_TMP="$(mktemp)"
    trap 'rm -f "$INB_TMP"' EXIT

    {
      inbound_rows | while read -r row_b64; do
        [[ -n "$row_b64" ]] || continue
        row_json="$(printf '%s' "$row_b64" | base64 -d)"
        p="$(json_get "$row_json" protocol)"
        tag="$(json_get "$row_json" tag)"
        port="$(json_get_num_or_empty "$row_json" port)"
        sni="$(json_get "$row_json" sni)"
        short_id="$(json_get "$row_json" reality_short_id)"
        obfs_type="$(json_get "$row_json" obfs_type)"
        obfs_pass="$(json_get "$row_json" obfs_password)"
        up="$(json_get_num_or_empty "$row_json" up_mbps)"
        down="$(json_get_num_or_empty "$row_json" down_mbps)"
        ports=""
        if [[ "$p" == "hy2" ]]; then
          ports="$(hy2_range_ports "$tag" "$port")"
        fi

        jq -cn \
          --arg protocol "$p" \
          --arg tag "$tag" \
          --arg port "$port" \
          --arg sni "$sni" \
          --arg short_id "$short_id" \
          --arg obfs_type "$obfs_type" \
          --arg obfs_pass "$obfs_pass" \
          --arg up "$up" \
          --arg down "$down" \
          --arg ports "$ports" \
          --arg hop "$HY2_RANGE_HOP_INTERVAL" '
          {
            protocol: $protocol,
            tag: $tag,
            port: ($port | tonumber),
            sni: $sni,
            reality_short_id: $short_id,
            obfs_type: $obfs_type,
            obfs_password: $obfs_pass,
            up_mbps: (if $up == "" then null else ($up | tonumber) end),
            down_mbps: (if $down == "" then null else ($down | tonumber) end),
            ports: (if $ports == "" then null else $ports end),
            hop_interval: (if $ports == "" then null else ($hop | tonumber? // $hop) end)
          }
        '
      done
    } | jq -s '.' > "$INB_TMP"

    jq \
      --arg filter "$filter_user" \
      --arg srv "$SERVER_IP" \
      --arg srv6 "${SERVER_IP6:-}" \
      --arg node "$NODE_NAME" \
      --arg pbk "$REALITY_PUBLIC_KEY" \
      --arg sid "$REALITY_SHORT_ID" \
      --arg default_rsni "$REALITY_SNI" \
      --arg default_hy2_sni "$HY2_SNI" \
      --arg domain "$MANAGED_DOMAIN" \
      --slurpfile inb "$INB_TMP" '
      def domain_field:
        if $domain == "" then {} else {domain: $domain} end;

      [
        .[]
        | select($filter == "" or (.name // "") == $filter or (.alias // "") == $filter)
        | . as $u
        | ({
            name: ($u.name // ""),
            alias: ($u.alias // ""),
            egress: ($u.egress // "direct"),
            uuid: ($u.uuid // ""),
            password: ($u.password // ""),
            nodes: [
              $inb[0][]
              | if .protocol == "vless" then
                  ({
                    protocol: "vless",
                    tag,
                    type: "vless",
                    server: $srv,
                    server_v6: $srv6,
                    port,
                    uuid: $u.uuid,
                    flow: "xtls-rprx-vision",
                    sni: (if .sni == "" then $default_rsni else .sni end),
                    pbk: $pbk,
                    sid: (if .reality_short_id == "" then $sid else .reality_short_id end)
                  } + domain_field)
                elif .protocol == "hy2" then
                  ({
                    protocol: "hy2",
                    tag,
                    type: "hysteria2",
                    server: $srv,
                    server_v6: $srv6,
                    port,
                    ports,
                    hop_interval,
                    password: $u.password,
                    sni: (if .sni == "" then $default_hy2_sni else .sni end),
                    obfs: (
                      if .obfs_type == "" then
                        null
                      else
                        {type: .obfs_type, password: .obfs_password}
                      end
                    ),
                    up_mbps,
                    down_mbps
                  } + domain_field)
                elif .protocol == "socks5" then
                  ({
                    protocol: "socks5",
                    tag,
                    type: "socks5",
                    server: $srv,
                    server_v6: $srv6,
                    port,
                    username: $u.name,
                    password: $u.password
                  } + domain_field)
                else
                  empty
                end
            ]
          } + domain_field)
      ]
    ' "$USERS_FILE"
    ;;
esac
